.min-h-screen.relative.flex.flex-col.items-center.justify-center.overflow-hidden.px-4.py-12{class: "bg-[#faf7f6] font-sans"}

  .absolute.rounded-full.pointer-events-none.top-0.-left-32{class: "bg-[#f5e6e8] blur-[100px] opacity-60 w-[600px] h-[600px]"}
  .absolute.rounded-full.pointer-events-none.bottom-10.-right-20{class: "bg-[#f8f4f2] blur-[80px] opacity-80 w-[500px] h-[500px]"}
  .absolute.bottom-4.right-4.w-64.h-64.rounded-full.pointer-events-none.opacity-40{class: "bg-[radial-gradient(circle_at_center,_#f5e6e8_0%,_transparent_70%)] blur-xl"}

  .relative.w-full.max-w-md.z-10.bg-white.p-8.md:p-10{class: "rounded-[2rem] shadow-[0_8px_40px_rgba(0,0,0,0.03)]"}

    .mb-8
      %h2.text-2xl.font-normal.mb-1{class: "text-[#333333]"}
        = t('.password_reset')
      %p.text-sm.leading-relaxed{class: "text-[#8a7b7e]"}
        = t('.enter_your_email_to_receive_reset_instructions')

    .mb-6
      = render "devise/shared/error_messages", resource: resource

    = form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-6" }) do |f|

      .field.group
        = f.label :email, class: "block text-[10px] font-semibold uppercase tracking-widest mb-2 text-[#8a7b7e] transition-colors group-focus-within:text-[#675458]"

        = f.email_field :email, autofocus: true, required: true, autocomplete: "email", placeholder: "name@example.com", class: "w-full border border-transparent rounded-xl px-4 py-3 text-sm text-[#333333] placeholder:text-[#cbb3b6] bg-[#faf7f6]/50 focus:bg-white focus:border-[#e9d5d8] focus:ring-4 focus:ring-[#f5e6e8]/50 transition-all outline-none"

      .pt-2
        %button.w-full.flex.items-center.justify-center.py-3.5.rounded-xl.text-white.text-sm.font-medium.transition-all{type: "submit", class: "bg-[#675458] hover:bg-[#5a2e35] shadow-sm hover:shadow-md"}
          = t('.send_recovery_email')

  .relative.z-10.mt-8
    = link_to new_session_path(resource_name), class: "group flex items-center gap-1.5 text-sm font-medium transition-colors text-[#8a7b7e] hover:text-[#675458]" do
      = lucide_icon("arrow-left", class: "w-3.5 h-3.5 transition-transform group-hover:-translate-x-1")
      = t('.go_back_to_login')
