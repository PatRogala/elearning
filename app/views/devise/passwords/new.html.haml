.min-h-screen.flex.flex-col.items-center.justify-center.px-4.py-12{class: "bg-[#f4f4f4]"}

  .w-full.max-w-md.bg-white.p-8.md:p-10.border{class: "rounded-[20px] border-[#c9c9cd]"}

    .mb-8
      %h2.text-2xl.font-medium.tracking-tight.mb-1{class: "text-[#191c1f]"}
        = t('.password_reset')
      %p.text-sm{class: "text-[#505a63] tracking-[0.24px]"}
        = t('.enter_your_email_to_receive_reset_instructions')

    .mb-6
      = render "devise/shared/error_messages", resource: resource

    = form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-6" }) do |f|

      .field.group
        = f.label :email, class: "block text-xs font-medium tracking-wide mb-2 text-[#8d969e] transition-colors group-focus-within:text-[#191c1f]"

        = f.email_field :email, autofocus: true, required: true, autocomplete: "email", placeholder: "name@example.com", class: "w-full border border-[#c9c9cd] rounded-xl px-4 py-3 text-sm text-[#191c1f] placeholder:text-[#8d969e] bg-[#f4f4f4] focus:bg-white focus:border-[#191c1f] focus:ring-4 focus:ring-[#191c1f]/10 transition-all outline-none"

      .pt-2
        %button.w-full.flex.items-center.justify-center.py-3.5.rounded-full.text-white.text-sm.font-medium.transition-opacity{type: "submit", class: "bg-[#191c1f] hover:opacity-85"}
          = t('.send_recovery_email')

  .mt-8
    = link_to new_session_path(resource_name), class: "group flex items-center gap-1.5 text-sm font-medium transition-colors text-[#505a63] hover:text-[#191c1f]" do
      = lucide_icon("arrow-left", class: "w-3.5 h-3.5 transition-transform group-hover:-translate-x-1")
      = t('.go_back_to_login')
