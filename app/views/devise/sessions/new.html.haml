.min-h-screen.relative.flex.flex-col.items-center.justify-center.overflow-hidden.px-6.py-12{class: "bg-[#faf7f6] font-sans"}

  .absolute.rounded-full.pointer-events-none.top-0.-left-32{class: "bg-[#f5e6e8] blur-[100px] opacity-60 w-[600px] h-[600px]"}
  .absolute.rounded-full.pointer-events-none.bottom-10.-right-20{class: "bg-[#f8f4f2] blur-[80px] opacity-80 w-[500px] h-[500px]"}

  .absolute.bottom-4.right-4.w-64.h-64.rounded-full.pointer-events-none.opacity-40{class: "bg-[radial-gradient(circle_at_center,_#f5e6e8_0%,_transparent_70%)] blur-xl"}

  .relative.z-10.flex.flex-col.items-center.mb-10
    %h1.text-3xl.font-light.tracking-wide{class: "text-[#333333]"}
      = Constants::APPLICATION_NAME
    %p.mt-2.text-sm{class: "text-[#8a7b7e]"}
      = t('.access_your_learning_dashboard')

  .relative.w-full.max-w-md.z-10.bg-white.p-8.md:p-10{class: "rounded-[2rem] shadow-[0_8px_40px_rgba(0,0,0,0.03)]"}

    .mb-8
      %h2.text-2xl.font-normal.mb-1{class: "text-[#333333]"}
        = t('.welcome_back')
      %p.text-sm{class: "text-[#8a7b7e]"}
        = t('.focus_mind')

    = form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f|

      .field.group
        = f.label :email, class: "block text-[10px] font-semibold uppercase tracking-widest mb-2 text-[#8a7b7e] transition-colors group-focus-within:text-[#675458]"

        = f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "name@example.com", class: "w-full border border-transparent rounded-xl px-4 py-3 text-sm text-[#333333] placeholder:text-[#cbb3b6] bg-[#faf7f6]/50 focus:bg-white focus:border-[#e9d5d8] focus:ring-4 focus:ring-[#f5e6e8]/50 transition-all outline-none"

      .field.group
        .flex.items-center.justify-between.mb-2
          = f.label :password, class: "block text-[10px] font-semibold uppercase tracking-widest text-[#8a7b7e] transition-colors group-focus-within:text-[#675458]"

          - if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations'
            = link_to t('.forgot_your_password', default: 'Forgot Password?'), new_password_path(resource_name), class: "text-[10px] font-semibold uppercase tracking-widest text-[#bfa2a6] hover:text-[#675458] transition-colors"

        = f.password_field :password, autocomplete: "current-password", placeholder: "••••••••", class: "w-full border border-transparent rounded-xl px-4 py-3 text-sm tracking-widest text-[#333333] placeholder:text-[#cbb3b6] bg-[#faf7f6]/50 focus:bg-white focus:border-[#e9d5d8] focus:ring-4 focus:ring-[#f5e6e8]/50 transition-all outline-none"

      .pt-2
        %button.w-full.flex.items-center.justify-center.py-3.5.rounded-xl.text-white.text-sm.font-medium.transition-all{type: "submit", class: "bg-[#675458] hover:bg-[#5a2e35] shadow-sm hover:shadow-md"}
          = t('.sign_in')

