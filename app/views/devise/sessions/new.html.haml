.min-h-screen.flex.flex-col.items-center.justify-start.pt-20.px-4{class: "bg-[#f4f4f4]"}

  .flex.flex-col.items-center.mb-10
    %p.mt-2.text-sm{class: "text-[#505a63] tracking-[0.24px]"}
      = t('.access_your_learning_dashboard')

  .w-full.max-w-md.bg-white.p-8.md:p-10.border{class: "rounded-[20px] border-[#c9c9cd]"}

    .mb-8
      %h2.text-2xl.font-medium.tracking-tight.mb-1{class: "text-[#191c1f]"}
        = t('.welcome_back')
      %p.text-sm{class: "text-[#505a63] tracking-[0.24px]"}
        = t('.focus_mind')

    = form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f|

      .field.group
        = f.label :email, class: "block text-xs font-medium tracking-wide mb-2 text-[#8d969e] transition-colors group-focus-within:text-[#191c1f]"

        = f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "name@example.com", class: "w-full border border-[#c9c9cd] rounded-xl px-4 py-3 text-sm text-[#191c1f] placeholder:text-[#8d969e] bg-[#f4f4f4] focus:bg-white focus:border-[#191c1f] focus:ring-4 focus:ring-[#191c1f]/10 transition-all outline-none"

      .field.group
        .flex.items-center.justify-between.mb-2
          = f.label :password, class: "block text-xs font-medium tracking-wide text-[#8d969e] transition-colors group-focus-within:text-[#191c1f]"

          - if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations'
            = link_to t('.forgot_your_password', default: 'Forgot Password?'), new_password_path(resource_name), class: "text-xs font-medium text-[#8d969e] hover:text-[#191c1f] transition-colors"

        = f.password_field :password, autocomplete: "current-password", placeholder: "••••••••", class: "w-full border border-[#c9c9cd] rounded-xl px-4 py-3 text-sm tracking-widest text-[#191c1f] placeholder:text-[#8d969e] bg-[#f4f4f4] focus:bg-white focus:border-[#191c1f] focus:ring-4 focus:ring-[#191c1f]/10 transition-all outline-none"

      .pt-2
        %button.w-full.flex.items-center.justify-center.py-3.5.rounded-full.text-white.text-sm.font-medium.transition-opacity{type: "submit", class: "bg-[#191c1f] hover:opacity-85"}
          = t('.sign_in')

