.min-h-screen.relative.flex.flex-col.items-center.justify-center.overflow-hidden.px-4.py-12{class: "bg-[#131313]"}
  .absolute.inset-0.opacity-20.pointer-events-none{class: "bg-[image:radial-gradient(#393939_1px,transparent_1px)] bg-[size:24px_24px]"}
  .absolute.rounded-full.pointer-events-none{class: "bg-[#E0115F]/5 w-[600px] h-[600px] blur-[150px]"}
  .relative.w-full.max-w-lg.z-10
    .flex.items-start.justify-between.mb-4.px-2
      .flex.flex-col.gap-1
        %span.font-bold.uppercase.tracking-widest{class: "text-[#E0115F] text-[10px]"}
          = t('.system_access_required')
        %span.font-mono.uppercase.tracking-widest{class: "text-[#5B3F44] text-[9px]"}
          S_ID: 104-RGSTR-ALPHA

      .shrink-0
        = lucide_icon("lock", class: "h-3 w-3 text-[#E0115F]")

    .p-8.md:p-12.shadow-2xl{class: "bg-[#1C1B1B] shadow-[0_0_80px_rgba(224,17,95,0.05)]"}
      %h1.font-black.uppercase.tracking-tighter.mb-4{class: "text-[#E5E2E1] text-4xl md:text-5xl"}
        = t('.create_your_learning_account')
      %p.mb-10.leading-relaxed{class: "text-[#E5E2E1]/60 text-sm md:text-base"}
        = t('.description')

      .mb-6
        = render "devise/shared/error_messages", resource: resource

      = form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-8" }) do |f|

        .grid.grid-cols-1.sm:grid-cols-2.gap-8
          .field.group
            = f.label :first_name, class: "block font-bold uppercase tracking-widest mb-3 transition-colors group-focus-within:text-[#E0115F] text-[#E5E2E1]/50 text-[10px]"
            .relative.border-b.pb-2.transition-colors{class: "border-[#5B3F44]/40 group-focus-within:border-[#E0115F]"}
              = f.text_field :first_name, autofocus: true, autocomplete: "given-name", placeholder: "CASE_SENSITIVE", class: "w-full bg-transparent border-0 p-0 pr-8 focus:ring-0 font-mono text-sm tracking-widest text-[#E5E2E1] placeholder:text-[#5B3F44]/50 outline-none"
              .absolute.right-0.bottom-2.pointer-events-none.transition-colors{class: "text-[#5B3F44]/50 group-focus-within:text-[#E0115F]"}
                = lucide_icon("user", class: "h-4 w-4 stroke-[2] text-[#5B3F44] group-focus-within:text-[#E0115F]")

          .field.group
            = f.label :last_name, class: "block font-bold uppercase tracking-widest mb-3 transition-colors group-focus-within:text-[#E0115F] text-[#E5E2E1]/50 text-[10px]"
            .relative.border-b.pb-2.transition-colors{class: "border-[#5B3F44]/40 group-focus-within:border-[#E0115F]"}
              = f.text_field :last_name, autocomplete: "family-name", placeholder: "INPUT", class: "w-full bg-transparent border-0 p-0 pr-8 focus:ring-0 font-mono text-sm tracking-widest text-[#E5E2E1] placeholder:text-[#5B3F44]/50 outline-none"
              .absolute.right-0.bottom-2.pointer-events-none.transition-colors{class: "text-[#5B3F44]/50 group-focus-within:text-[#E0115F]"}
                = lucide_icon("user", class: "h-4 w-4 stroke-[2] text-[#5B3F44] group-focus-within:text-[#E0115F]")

        .field.group
          = f.label :email, class: "block font-bold uppercase tracking-widest mb-3 transition-colors group-focus-within:text-[#E0115F] text-[#E5E2E1]/50 text-[10px]"
          .relative.border-b.pb-2.transition-colors{class: "border-[#5B3F44]/40 group-focus-within:border-[#E0115F]"}
            = f.email_field :email, autocomplete: "email", placeholder: "USR_ID@MONOLITH.EDU", class: "w-full bg-transparent border-0 p-0 pr-8 focus:ring-0 font-mono text-sm tracking-widest text-[#E5E2E1] placeholder:text-[#5B3F44]/50 outline-none"
            .absolute.right-0.bottom-2.pointer-events-none.transition-colors{class: "text-[#5B3F44]/50 group-focus-within:text-[#E0115F]"}
              = lucide_icon("mail", class: "h-4 w-4 stroke-[2] text-[#5B3F44] group-focus-within:text-[#E0115F]")

        .field.group
          = f.label :password, class: "block font-bold uppercase tracking-widest mb-3 transition-colors group-focus-within:text-[#E0115F] text-[#E5E2E1]/50 text-[10px]"
          .relative.border-b.pb-2.transition-colors{class: "border-[#5B3F44]/40 group-focus-within:border-[#E0115F]"}
            = f.password_field :password, autocomplete: "new-password", placeholder: "••••••••••••", class: "w-full bg-transparent border-0 p-0 pr-8 focus:ring-0 font-mono text-sm tracking-widest text-[#E5E2E1] placeholder:text-[#5B3F44]/50 outline-none"
            .absolute.right-0.bottom-2.pointer-events-none.transition-colors{class: "text-[#5B3F44]/50 group-focus-within:text-[#E0115F]"}
              = lucide_icon("lock", class: "h-4 w-4 stroke-[2] text-[#5B3F44] group-focus-within:text-[#E0115F]")
          - if @minimum_password_length
            %p.mt-2.font-mono.uppercase.tracking-widest{class: "text-[#5B3F44] text-[9px]"}
              = t('.min_length', count: @minimum_password_length)

        .field.group
          = f.label :password_confirmation, class: "block font-bold uppercase tracking-widest mb-3 transition-colors group-focus-within:text-[#E0115F] text-[#E5E2E1]/50 text-[10px]"
          .relative.border-b.pb-2.transition-colors{class: "border-[#5B3F44]/40 group-focus-within:border-[#E0115F]"}
            = f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••••••", class: "w-full bg-transparent border-0 p-0 pr-8 focus:ring-0 font-mono text-sm tracking-widest text-[#E5E2E1] placeholder:text-[#5B3F44]/50 outline-none"
            .absolute.right-0.bottom-2.pointer-events-none.transition-colors{class: "text-[#5B3F44]/50 group-focus-within:text-[#E0115F]"}
              = lucide_icon("lock", class: "h-4 w-4 stroke-[2] text-[#5B3F44] group-focus-within:text-[#E0115F]")

        .pt-4
          %button.w-full.flex.items-center.justify-center.gap-3.py-4.font-bold.uppercase.tracking-widest.transition-all.rounded-sm{type: "submit", class: "bg-[#E0115F] hover:bg-[#E0115F]/90 text-[#FFF8F8] text-sm shadow-[0_0_15px_rgba(224,17,95,0.15)]"}
            = t('.sign_up')
            = lucide_icon("arrow-right", class: "h-4 w-4 stroke-[2] text-[#FFF8F8]")

      .mt-10.pt-8.border-t.flex.items-center.justify-between{class: "border-[#5B3F44]/20"}
        %span.font-mono.uppercase.tracking-widest{class: "text-[#5B3F44] text-[10px]"}
          = t('.already_registered')
        = link_to t('.sign_in'), new_session_path(resource_name), class: "font-bold uppercase tracking-widest transition-opacity hover:opacity-80 text-[#E0115F] text-[11px]"

    .mt-6.flex.flex-col.gap-1.font-mono.uppercase.tracking-widest.px-2{class: "text-[#5B3F44] text-[9px]"}
      %span CPU_LOAD: 12.04%
      %span MEMORY: 2.4GB/32GB
