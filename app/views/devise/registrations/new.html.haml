.min-h-screen.relative.flex.flex-col.items-center.justify-center.overflow-hidden.px-4.py-12{class: "bg-[#faf7f6] font-sans"}

  .absolute.rounded-full.pointer-events-none.top-0.-left-32{class: "bg-[#f5e6e8] blur-[100px] opacity-60 w-[600px] h-[600px]"}
  .absolute.rounded-full.pointer-events-none.bottom-10.-right-20{class: "bg-[#f8f4f2] blur-[80px] opacity-80 w-[500px] h-[500px]"}
  .absolute.bottom-4.right-4.w-64.h-64.rounded-full.pointer-events-none.opacity-40{class: "bg-[radial-gradient(circle_at_center,_#f5e6e8_0%,_transparent_70%)] blur-xl"}

  .relative.z-10.flex.flex-col.items-center.mb-10
    %h1.text-3xl.font-light.tracking-wide{class: "text-[#333333]"}
      = Constants::APPLICATION_NAME

  .relative.w-full.max-w-lg.z-10.bg-white.p-8.md:p-10{class: "rounded-[2rem] shadow-[0_8px_40px_rgba(0,0,0,0.03)]"}

    .mb-8
      %h2.text-2xl.font-normal.mb-1{class: "text-[#333333]"}
        = t('.create_your_learning_account')
      %p.text-sm{class: "text-[#8a7b7e]"}
        = t('.description')

    .mb-6
      = render "devise/shared/error_messages", resource: resource

    = form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f|

      .grid.grid-cols-1.sm:grid-cols-2.gap-6
        .field.group
          = f.label :first_name, class: "block text-[10px] font-semibold uppercase tracking-widest mb-2 text-[#8a7b7e] transition-colors group-focus-within:text-[#675458]"
          = f.text_field :first_name, autofocus: true, autocomplete: "given-name", placeholder: "Jane", class: "w-full border border-transparent rounded-xl px-4 py-3 text-sm text-[#333333] placeholder:text-[#cbb3b6] bg-[#faf7f6]/50 focus:bg-white focus:border-[#e9d5d8] focus:ring-4 focus:ring-[#f5e6e8]/50 transition-all outline-none"

        .field.group
          = f.label :last_name, class: "block text-[10px] font-semibold uppercase tracking-widest mb-2 text-[#8a7b7e] transition-colors group-focus-within:text-[#675458]"
          = f.text_field :last_name, autocomplete: "family-name", placeholder: "Doe", class: "w-full border border-transparent rounded-xl px-4 py-3 text-sm text-[#333333] placeholder:text-[#cbb3b6] bg-[#faf7f6]/50 focus:bg-white focus:border-[#e9d5d8] focus:ring-4 focus:ring-[#f5e6e8]/50 transition-all outline-none"

      .field.group
        = f.label :email, class: "block text-[10px] font-semibold uppercase tracking-widest mb-2 text-[#8a7b7e] transition-colors group-focus-within:text-[#675458]"
        = f.email_field :email, autocomplete: "email", placeholder: "name@example.com", class: "w-full border border-transparent rounded-xl px-4 py-3 text-sm text-[#333333] placeholder:text-[#cbb3b6] bg-[#faf7f6]/50 focus:bg-white focus:border-[#e9d5d8] focus:ring-4 focus:ring-[#f5e6e8]/50 transition-all outline-none"

      .field.group
        = f.label :password, class: "block text-[10px] font-semibold uppercase tracking-widest mb-2 text-[#8a7b7e] transition-colors group-focus-within:text-[#675458]"
        = f.password_field :password, autocomplete: "new-password", placeholder: "••••••••", class: "w-full border border-transparent rounded-xl px-4 py-3 text-sm tracking-widest text-[#333333] placeholder:text-[#cbb3b6] bg-[#faf7f6]/50 focus:bg-white focus:border-[#e9d5d8] focus:ring-4 focus:ring-[#f5e6e8]/50 transition-all outline-none"
        - if @minimum_password_length
          %p.mt-2.uppercase.tracking-widest{class: "text-[#bfa2a6] text-[10px]"}
            = t('.min_length', count: @minimum_password_length)

      .field.group
        = f.label :password_confirmation, class: "block text-[10px] font-semibold uppercase tracking-widest mb-2 text-[#8a7b7e] transition-colors group-focus-within:text-[#675458]"
        = f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••", class: "w-full border border-transparent rounded-xl px-4 py-3 text-sm tracking-widest text-[#333333] placeholder:text-[#cbb3b6] bg-[#faf7f6]/50 focus:bg-white focus:border-[#e9d5d8] focus:ring-4 focus:ring-[#f5e6e8]/50 transition-all outline-none"

      .pt-4
        %button.w-full.flex.items-center.justify-center.py-3.5.rounded-xl.text-white.text-sm.font-medium.transition-all{type: "submit", class: "bg-[#675458] hover:bg-[#5a2e35] shadow-sm hover:shadow-md"}
          = t('.sign_up')

  .relative.z-10.mt-6.text-sm{class: "text-[#8a7b7e]"}
    = t('.already_registered')
    = link_to t('.sign_in'), new_session_path(resource_name), class: "font-medium transition-colors hover:underline ml-1 text-[#675458]"
