.min-h-screen.flex.flex-col.items-center.justify-center.px-4.py-12{class: "bg-[#f4f4f4]"}

  .w-full.max-w-lg.bg-white.p-8.md:p-10.border{class: "rounded-[20px] border-[#c9c9cd]"}

    .mb-8
      %h2.text-2xl.font-medium.tracking-tight.mb-1{class: "text-[#191c1f]"}
        = t('.create_your_learning_account')
      %p.text-sm{class: "text-[#505a63] tracking-[0.24px]"}
        = t('.description')

    .mb-6
      = render "devise/shared/error_messages", resource: resource

    = form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f|

      .grid.grid-cols-1.sm:grid-cols-2.gap-6
        .field.group
          = f.label :first_name, class: "block text-xs font-medium tracking-wide mb-2 text-[#8d969e] transition-colors group-focus-within:text-[#191c1f]"
          = f.text_field :first_name, autofocus: true, autocomplete: "given-name", placeholder: "Jane", class: "w-full border border-[#c9c9cd] rounded-xl px-4 py-3 text-sm text-[#191c1f] placeholder:text-[#8d969e] bg-[#f4f4f4] focus:bg-white focus:border-[#191c1f] focus:ring-4 focus:ring-[#191c1f]/10 transition-all outline-none"

        .field.group
          = f.label :last_name, class: "block text-xs font-medium tracking-wide mb-2 text-[#8d969e] transition-colors group-focus-within:text-[#191c1f]"
          = f.text_field :last_name, autocomplete: "family-name", placeholder: "Doe", class: "w-full border border-[#c9c9cd] rounded-xl px-4 py-3 text-sm text-[#191c1f] placeholder:text-[#8d969e] bg-[#f4f4f4] focus:bg-white focus:border-[#191c1f] focus:ring-4 focus:ring-[#191c1f]/10 transition-all outline-none"

      .field.group
        = f.label :email, class: "block text-xs font-medium tracking-wide mb-2 text-[#8d969e] transition-colors group-focus-within:text-[#191c1f]"
        = f.email_field :email, autocomplete: "email", placeholder: "name@example.com", class: "w-full border border-[#c9c9cd] rounded-xl px-4 py-3 text-sm text-[#191c1f] placeholder:text-[#8d969e] bg-[#f4f4f4] focus:bg-white focus:border-[#191c1f] focus:ring-4 focus:ring-[#191c1f]/10 transition-all outline-none"

      .field.group
        = f.label :password, class: "block text-xs font-medium tracking-wide mb-2 text-[#8d969e] transition-colors group-focus-within:text-[#191c1f]"
        = f.password_field :password, autocomplete: "new-password", placeholder: "••••••••", class: "w-full border border-[#c9c9cd] rounded-xl px-4 py-3 text-sm tracking-widest text-[#191c1f] placeholder:text-[#8d969e] bg-[#f4f4f4] focus:bg-white focus:border-[#191c1f] focus:ring-4 focus:ring-[#191c1f]/10 transition-all outline-none"
        - if @minimum_password_length
          %p.mt-2.text-xs{class: "text-[#8d969e] tracking-[0.16px]"}
            = t('.min_length', count: @minimum_password_length)

      .field.group
        = f.label :password_confirmation, class: "block text-xs font-medium tracking-wide mb-2 text-[#8d969e] transition-colors group-focus-within:text-[#191c1f]"
        = f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••", class: "w-full border border-[#c9c9cd] rounded-xl px-4 py-3 text-sm tracking-widest text-[#191c1f] placeholder:text-[#8d969e] bg-[#f4f4f4] focus:bg-white focus:border-[#191c1f] focus:ring-4 focus:ring-[#191c1f]/10 transition-all outline-none"

      .pt-4
        %button.w-full.flex.items-center.justify-center.py-3.5.rounded-full.text-white.text-sm.font-medium.transition-opacity{type: "submit", class: "bg-[#191c1f] hover:opacity-85"}
          = t('.sign_up')

  .mt-6.text-sm{class: "text-[#505a63]"}
    = t('.already_registered')
    = link_to t('.sign_in'), new_session_path(resource_name), class: "font-medium transition-colors hover:underline ml-1 text-[#191c1f]"
