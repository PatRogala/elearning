.min-h-screen.px-6.md:px-12.py-20.lg:py-32{class: "bg-white font-sans"}

  .max-w-7xl.mx-auto

    .mb-16.text-center.md:text-left
      .flex.items-center.justify-center.md:justify-start.gap-4.mb-4
        %span.h-px.w-12{class: "bg-[#c9c9cd]"}
        %span.font-semibold.uppercase.tracking-widest{class: "text-[#8d969e] text-[10px]"}
          = t(".title")
      %h1.text-5xl.md:text-7xl.font-medium.tracking-tight{class: "text-[#191c1f]", style: "letter-spacing: -0.8px"}
        = t(".projects")

    .p-10.md:p-16.flex.flex-col.lg:flex-row.justify-between.gap-16.items-center{class: "bg-[#f4f4f4] rounded-[1.25rem]"}

      .max-w-2xl

        %h2.text-4xl.md:text-5xl.font-medium.tracking-tight.mb-6{class: "text-[#191c1f]", style: "letter-spacing: -0.4px"}
          = t(".coming_soon", default: "Coming Soon")

        %p.leading-relaxed.text-base.md:text-lg{class: "text-[#505a63]"}
          = t(".description", default: "We are crafting a beautiful experience for project-based learning. Stay tuned for immersive, real-world coding challenges designed to expand your digital future.")

      .flex.flex-col.justify-end.w-full.lg:w-auto{class: "lg:min-w-[320px]"}
        .w-full.h-2.rounded-full.mb-3.overflow-hidden{class: "bg-white"}
          .h-full.rounded-full.transition-all.duration-1000{class: "bg-[#191c1f] w-[74.2%]"}
