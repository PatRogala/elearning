.min-h-screen.relative.overflow-hidden.px-6.md:px-12.py-20.lg:py-32{class: "bg-[#131313]"}
  .absolute.inset-0.opacity-20.pointer-events-none{class: "bg-[image:radial-gradient(#393939_1px,transparent_1px)] bg-[size:24px_24px]"}
  .max-w-7xl.mx-auto.relative.z-10
    .mb-16
      .flex.items-center.gap-4.mb-4
        %span.h-px.w-12{class: "bg-[#E0115F]"}
        %span.font-bold.uppercase.tracking-widest{class: "text-[#E0115F] text-[10px]"}
          Project_Manifest
      %h1.font-black.uppercase.tracking-tighter.leading-none{class: "text-[#E5E2E1] text-5xl md:text-7xl lg:text-[7vw]"}
        SZKOLEO_PROJECTS
    .relative.p-8.md:p-12.lg:p-16.shadow-2xl.flex.flex-col.lg:flex-row.justify-between.gap-12{class: "bg-[#1C1B1B] border-l-4 border-[#E0115F] shadow-[0_0_80px_rgba(0,0,0,0.6)]"}
      .absolute.top-8.right-8.hidden.md:flex.flex-col.items-end.font-mono.uppercase.tracking-widest.text-right{class: "text-[#5B3F44] text-[9px] leading-relaxed"}
        %span SYS_REF: 0XFD29A
        %span AUTH: ROOT_ADMIN
        %span STABILITY: UNSTABLE_BUILD

      .max-w-2xl
        .inline-flex.items-center.gap-2.px-3.py-1.border.rounded-sm.mb-8{class: "bg-[#E0115F]/10 border-[#E0115F]/30"}
          %span.relative.flex.h-2.w-2
            %span.animate-ping.absolute.inline-flex.h-full.w-full.rounded-full.opacity-75{class: "bg-[#E0115F]"}
            %span.relative.inline-flex.rounded-full.h-2.w-2{class: "bg-[#E0115F]"}
          %span.font-mono.font-bold.uppercase.tracking-widest{class: "text-[#E0115F] text-[9px]"}
            = t(".system_status")

        %h2.font-black.uppercase.tracking-tighter.mb-6{class: "text-[#E5E2E1] text-5xl md:text-7xl"}
          = t(".coming_soon")

        %p.leading-relaxed.font-medium{class: "text-[#E5E2E1]/70 text-base md:text-lg lg:text-xl"}
          = t(".description")

      .flex.flex-col.justify-end.mt-8.lg:mt-0{class: "lg:min-w-[300px]"}
        .w-full.h-1.mb-3{class: "bg-[#5B3F44]/30"}
          .h-full.relative{class: "bg-[#E0115F] w-[74.2%] shadow-[0_0_10px_rgba(224,17,95,0.5)]"}
            .absolute.right-0.w-1.h-3.bg-white.animate-pulse{class: "top-1/2 -translate-y-1/2"}

        .flex.items-center.justify-between.font-mono.uppercase.tracking-widest{class: "text-[9px]"}
          %span{class: "text-[#E5E2E1]/50"} Compile_Progress
          %span{class: "text-[#E0115F]"} 74.2%
