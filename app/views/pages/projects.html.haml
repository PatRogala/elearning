.min-h-screen.relative.overflow-hidden.px-6.md:px-12.py-20.lg:py-32{class: "bg-[#faf7f6] font-sans"}

  .absolute.rounded-full.pointer-events-none.-top-40.-left-40{class: "bg-[#f5e6e8] blur-[120px] opacity-60 w-[800px] h-[800px]"}
  .absolute.rounded-full.pointer-events-none.bottom-0.right-0{class: "bg-[#f8f4f2] blur-[100px] opacity-80 w-[600px] h-[600px]"}

  .max-w-7xl.mx-auto.relative.z-10

    .mb-16.text-center.md:text-left
      .flex.items-center.justify-center.md:justify-start.gap-4.mb-4
        %span.h-px.w-12{class: "bg-[#e9d5d8]"}
        %span.font-semibold.uppercase.tracking-widest{class: "text-[#8a7b7e] text-[10px]"}
          = t(".title")
      %h1.text-5xl.md:text-7xl.font-light.tracking-tight{class: "text-[#333333]"}
        = t(".projects")

    .relative.p-10.md:p-16.flex.flex-col.lg:flex-row.justify-between.gap-16.items-center{class: "bg-white rounded-[2.5rem] shadow-[0_8px_40px_rgba(0,0,0,0.03)]"}

      .max-w-2xl

        %h2.text-4xl.md:text-5xl.font-light.tracking-tight.mb-6{class: "text-[#333333]"}
          = t(".coming_soon", default: "Coming Soon")

        %p.leading-relaxed.text-base.md:text-lg{class: "text-[#8a7b7e]"}
          = t(".description", default: "We are crafting a beautiful experience for project-based learning. Stay tuned for immersive, real-world coding challenges designed to expand your digital future.")

      .flex.flex-col.justify-end.w-full.lg:w-auto{class: "lg:min-w-[320px]"}
        .w-full.h-2.rounded-full.mb-3.overflow-hidden{class: "bg-[#faf7f6] border border-[#f5e6e8]"}
          .h-full.rounded-full.relative.transition-all.duration-1000{class: "bg-[#e9d5d8] w-[74.2%]"}
            .absolute.right-0.top-0.w-4.h-full.rounded-full{class: "bg-white/40 blur-[2px]"}
