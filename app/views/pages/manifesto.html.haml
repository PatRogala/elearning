.min-h-screen.relative.overflow-hidden.px-6.md:px-12.py-20.lg:py-32{class: "bg-[#faf7f6] font-sans"}
  .absolute.rounded-full.pointer-events-none.-top-40.-left-40{class: "bg-[#f5e6e8] blur-[120px] opacity-60 w-[800px] h-[800px]"}
  .absolute.rounded-full.pointer-events-none.-right-64{class: "bg-[#f8f4f2] blur-[120px] opacity-80 w-[800px] h-[800px] top-1/2"}

  .max-w-7xl.mx-auto.relative.z-10

    .mb-24.md:mb-32
      %span.block.font-semibold.uppercase.tracking-widest.mb-6{class: "text-[#8a7b7e] text-[10px]"}
        = t(".overline")

      %h1.text-5xl.md:text-7xl.font-light.tracking-tight.mb-8{class: "text-[#333333] lg:text-[8vw] leading-[1.1]"}
        = Constants::APPLICATION_NAME
        %span.italic{class: "text-[#675458]"}
          = t(".title")

      %p.text-lg.md:text-2xl.font-normal.leading-relaxed.max-w-3xl{class: "text-[#8a7b7e]"}
        = t(".mission")

    .grid.grid-cols-1.md:grid-cols-2.gap-16.lg:gap-24.mb-24.lg:mb-32

      .flex.flex-col
        .flex.items-center.gap-4.mb-6
          %span.text-sm.font-medium{class: "text-[#cbb3b6]"} 01
          .h-px.flex-1{class: "bg-[#e9d5d8]"}

        %h2.text-2xl.md:text-3xl.font-normal.tracking-tight.mb-4{class: "text-[#333333]"}
          = t(".access_without_barriers")

        %p.leading-relaxed.text-base.md:text-lg{class: "text-[#8a7b7e]"}
          = t(".access_without_barriers_description")

      .flex.flex-col
        .flex.items-center.gap-4.mb-6
          %span.text-sm.font-medium{class: "text-[#cbb3b6]"} 02
          .h-px.flex-1{class: "bg-[#e9d5d8]"}

        %h2.text-2xl.md:text-3xl.font-normal.tracking-tight.mb-4{class: "text-[#333333]"}
          = t(".radical_transparency")

        %p.leading-relaxed.text-base.md:text-lg{class: "text-[#8a7b7e]"}
          = t(".radical_transparency_description")

    .max-w-5xl.mx-auto.mb-32
      .p-10.md:p-16.relative.bg-white{class: "rounded-[2.5rem] shadow-[0_8px_40px_rgba(0,0,0,0.03)]"}

        .absolute.top-10.right-10.hidden.sm:block{class: "text-[#e9d5d8]"}
          = lucide_icon("sparkles", class: "w-6 h-6")

        .flex.items-baseline.gap-4.mb-10
          %span.text-sm.font-medium{class: "text-[#cbb3b6]"} 03
          %h2.text-3xl.md:text-4xl.font-normal.tracking-tight{class: "text-[#333333]"}
            = t(".focus_on_content")

        .grid.grid-cols-1.lg:grid-cols-2.gap-12.items-center
          %p.leading-relaxed.text-base.md:text-lg{class: "text-[#8a7b7e]"}
            = t(".focus_on_content_description")

          .p-6.rounded-2xl.font-mono.leading-loose.overflow-x-auto{class: "bg-[#faf7f6] border border-[#f5e6e8] text-[11px]"}
            %div{class: "text-[#bfa2a6] mb-4"}
            %div{class: "text-[#675458]"}
              %span{class: "text-[#8a7b7e]"} while
              (knowledge.expanding) {
            %div.pl-4{class: "text-[#675458]"}
              absorb_concepts();
            %div.pl-4{class: "text-[#8a7b7e]"}
              apply_to_reality();
            %div{class: "text-[#675458]"} }

    .border-t.pt-20.pb-12.text-center{class: "border-[#f5e6e8]"}

      %h3.text-4xl.md:text-5xl.lg:text-6xl.font-light.tracking-tight.mb-2{class: "text-[#333333]"}
        = t(".not_a_product")
      %h3.text-4xl.md:text-5xl.lg:text-6xl.font-light.italic.tracking-tight{class: "text-[#675458]"}
        = t(".not_a_product_description")

      .flex.items-center.justify-center.gap-12.mt-16
        .flex.flex-col.items-center
          %span.text-xl.md:text-2xl.font-light{class: "text-[#333333]"} 100%
          %span.uppercase.tracking-widest.mt-2.font-semibold{class: "text-[#8a7b7e] text-[10px]"}
            = t(".value_1")

        .w-px.h-8{class: "bg-[#e9d5d8]"}

        .flex.flex-col.items-center
          %span.text-xl.md:text-2xl{class: "text-[#333333]"}
            = lucide_icon("infinity", class: "w-6 h-6 stroke-1")
          %span.uppercase.tracking-widest.mt-2.font-semibold{class: "text-[#8a7b7e] text-[10px]"}
            = t(".value_2")
