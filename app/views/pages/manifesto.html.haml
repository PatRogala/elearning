.min-h-screen.px-6.md:px-12.py-20.lg:py-32{class: "bg-white font-sans"}

  .max-w-7xl.mx-auto

    .mb-24.md:mb-32
      %span.block.font-semibold.uppercase.tracking-widest.mb-6{class: "text-[#8d969e] text-[10px]"}
        = t(".overline")

      %h1.text-5xl.md:text-7xl.font-medium.tracking-tight.mb-8.flex.items-center.gap-5{class: "text-[#191c1f] lg:text-[8vw] leading-[1.0]", style: "letter-spacing: -0.8px"}
        %span.italic
          = t(".title")

      %p.text-lg.md:text-2xl.font-normal.leading-relaxed.max-w-3xl{class: "text-[#505a63]"}
        = t(".mission")

    .grid.grid-cols-1.md:grid-cols-2.gap-16.lg:gap-24.mb-24.lg:mb-32

      .flex.flex-col
        .flex.items-center.gap-4.mb-6
          %span.text-sm.font-medium{class: "text-[#8d969e]"} 01
          .h-px.flex-1{class: "bg-[#c9c9cd]"}

        %h2.text-2xl.md:text-3xl.font-medium.tracking-tight.mb-4{class: "text-[#191c1f]"}
          = t(".access_without_barriers")

        %p.leading-relaxed.text-base.md:text-lg{class: "text-[#505a63]"}
          = t(".access_without_barriers_description")

      .flex.flex-col
        .flex.items-center.gap-4.mb-6
          %span.text-sm.font-medium{class: "text-[#8d969e]"} 02
          .h-px.flex-1{class: "bg-[#c9c9cd]"}

        %h2.text-2xl.md:text-3xl.font-medium.tracking-tight.mb-4{class: "text-[#191c1f]"}
          = t(".radical_transparency")

        %p.leading-relaxed.text-base.md:text-lg{class: "text-[#505a63]"}
          = t(".radical_transparency_description")

    .max-w-5xl.mx-auto.mb-32
      .p-10.md:p-16.relative{class: "bg-[#f4f4f4] rounded-[1.25rem]"}

        .absolute.top-10.right-10.hidden.sm:block{class: "text-[#c9c9cd]"}
          = lucide_icon("sparkles", class: "w-6 h-6")

        .flex.items-baseline.gap-4.mb-10
          %span.text-sm.font-medium{class: "text-[#8d969e]"} 03
          %h2.text-3xl.md:text-4xl.font-medium.tracking-tight{class: "text-[#191c1f]"}
            = t(".focus_on_content")

        .grid.grid-cols-1.lg:grid-cols-2.gap-12.items-center
          %p.leading-relaxed.text-base.md:text-lg{class: "text-[#505a63]"}
            = t(".focus_on_content_description")

          .p-6.rounded-2xl.font-mono.leading-loose.overflow-x-auto{class: "bg-white text-[11px]"}
            %div{class: "text-[#8d969e] mb-4"}
            %div{class: "text-[#191c1f]"}
              %span{class: "text-[#494fdf]"} while
              (knowledge.expanding) {
            %div.pl-4{class: "text-[#505a63]"}
              absorb_concepts();
            %div.pl-4{class: "text-[#505a63]"}
              apply_to_reality();
            %div{class: "text-[#191c1f]"} }

    .border-t.pt-20.pb-12.text-center{class: "border-[#c9c9cd]"}

      %h3.text-4xl.md:text-5xl.lg:text-6xl.font-medium.tracking-tight.mb-2{class: "text-[#191c1f]", style: "letter-spacing: -0.48px"}
        = t(".not_a_product")
      %h3.text-4xl.md:text-5xl.lg:text-6xl.font-medium.italic.tracking-tight{class: "text-[#191c1f]", style: "letter-spacing: -0.48px"}
        = t(".not_a_product_description")

      .flex.items-center.justify-center.gap-12.mt-16
        .flex.flex-col.items-center
          %span.text-xl.md:text-2xl.font-medium{class: "text-[#191c1f]"} 100%
          %span.uppercase.tracking-widest.mt-2.font-semibold{class: "text-[#8d969e] text-[10px]"}
            = t(".value_1")

        .w-px.h-8{class: "bg-[#c9c9cd]"}

        .flex.flex-col.items-center
          %span.text-xl.md:text-2xl{class: "text-[#191c1f]"}
            = lucide_icon("infinity", class: "w-6 h-6 stroke-1")
          %span.uppercase.tracking-widest.mt-2.font-semibold{class: "text-[#8d969e] text-[10px]"}
            = t(".value_2")
