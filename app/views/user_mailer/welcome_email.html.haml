%table{border: "0", cellpadding: "0", cellspacing: "0", width: "100%", style: "background-color: #f5f5f5; padding: 40px 20px;"}
  %tr
    %td{align: "center"}

      %table{border: "0", cellpadding: "0", cellspacing: "0", width: "100%", style: "max-width: 600px; background-color: #ffffff; border: 2px solid #171717; border-collapse: collapse;"}

        %tr
          %td{align: "left", style: "padding: 20px 30px; border-bottom: 2px solid #171717; background-color: #171717;"}
            %table{border: "0", cellpadding: "0", cellspacing: "0", width: "100%"}
              %tr
                %td{style: "color: #ffffff; font-size: 14px; font-weight: 900; letter-spacing: 0.15em; text-transform: uppercase;"}
                  = t("user_mailer.welcome_email.logo")
                %td{align: "right", style: "color: #737373; font-size: 10px; font-weight: bold; letter-spacing: 0.2em; text-transform: uppercase;"}
                  = t("user_mailer.welcome_email.system_message")

        %tr
          %td{align: "left", style: "padding: 40px 30px; border-bottom: 2px solid #171717;"}
            %p{style: "margin: 0 0 10px 0; color: #737373; font-size: 10px; font-weight: bold; letter-spacing: 0.2em; text-transform: uppercase;"}
              = t("user_mailer.welcome_email.status")

            %h1{style: "margin: 0 0 20px 0; color: #171717; font-size: 36px; font-weight: 900; text-transform: uppercase; line-height: 1.1; letter-spacing: -0.02em;"}
              = t("user_mailer.welcome_email.greeting")
              %br
              = t("user_mailer.welcome_email.greeting_2")

            %p{style: "margin: 0; color: #404040; font-size: 16px; line-height: 1.6;"}
              = t("user_mailer.welcome_email.greeting_3", first_name: @user.first_name || "Nieznajomy")
              %br
              %br
              = t("user_mailer.welcome_email.instruction")

        %tr
          %td{align: "center", style: "padding: 40px 30px; background-color: #fafafa; border-bottom: 2px solid #171717;"}

            %table{border: "0", cellpadding: "0", cellspacing: "0"}
              %tr
                %td{align: "center", style: "background-color: #171717; border: 1px solid #171717;"}
                  %a{href: courses_url, target: "_blank", style: "display: inline-block; padding: 18px 32px; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; color: #ffffff; font-size: 12px; font-weight: bold; letter-spacing: 0.2em; text-transform: uppercase; text-decoration: none; border: 1px solid #171717;"}
                    = t("user_mailer.welcome_email.browse_catalog")
                    &rarr;

            %p{style: "margin: 15px 0 0 0; color: #737373; font-size: 10px; font-weight: bold; letter-spacing: 0.1em; text-transform: uppercase;"}
              = t("user_mailer.welcome_email.click_button")

        %tr
          %td{align: "left", style: "padding: 30px; background-color: #ffffff;"}
            %table{border: "0", cellpadding: "0", cellspacing: "0", width: "100%"}
              %tr
                %td{width: "50%", align: "left", style: "color: #737373; font-size: 10px; font-weight: bold; letter-spacing: 0.15em; text-transform: uppercase; line-height: 1.5;"}
                  = t("user_mailer.welcome_email.logo")
                %td{width: "50%", align: "right", style: "color: #737373; font-size: 10px; font-weight: bold; letter-spacing: 0.15em; text-transform: uppercase; line-height: 1.5;"}
                  %a{href: edit_user_registration_url, style: "color: #171717; text-decoration: none; border-bottom: 1px solid #171717;"}
                    = t("user_mailer.welcome_email.your_profile")

      %table{border: "0", cellpadding: "0", cellspacing: "0", width: "100%", style: "max-width: 600px;"}
        %tr
          %td{align: "center", style: "padding: 20px 0; color: #a3a3a3; font-size: 9px; font-weight: bold; letter-spacing: 0.1em; text-transform: uppercase;"}
            = t("user_mailer.welcome_email.unsubscribe")
            %a{href: "#", style: "color: #171717; text-decoration: underline;"}
              = t("user_mailer.welcome_email.unsubscribe_button")
            \.
