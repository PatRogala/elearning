%div{class: container_classes, data: { controller: "flash" }, role: "alert"}
  %div{class: left_indicator_classes}
  .shrink-0.pl-5.pr-1
    = lucide_icon(icon_name, class: "h-5 w-5 stroke-[2] #{icon_classes}")

  .flex-1.min-w-0.py-1
    %p{class: title_classes}
      = message

  %button.shrink-0.p-2.transition-colors.rounded-sm{type: "button", "aria-label" => "Dismiss", "data-action" => "click->flash#dismiss", class: "text-[#E5E2E1]/30 hover:text-[#E5E2E1]/80 hover:bg-[#393939]/50"}
    = lucide_icon("x", class: "h-4 w-4 stroke-[2]")
