%footer.bg-white.border-t.border-neutral-900
  .mx-auto.border-x.border-neutral-900

    .grid.grid-cols-1.lg:grid-cols-12

      .lg:col-span-4.p-6.md:p-12.border-b.lg:border-b-0.lg:border-r.border-neutral-900.flex.flex-col.justify-between
        %div
          %h2.text-4xl.font-black.uppercase.tracking-tighter.text-neutral-900.mb-4
            = Constants::APPLICATION_NAME

          %p.text-sm.text-neutral-600.leading-relaxed.mb-8.max-w-xs
            = t(".description")

      .lg:col-span-8.grid.grid-cols-1.sm:grid-cols-3

        .p-6.md:p-12.border-b.sm:border-b-0.sm:border-r.border-neutral-900.flex.flex-col
          %span.block.font-bold.uppercase.text-neutral-400.mb-8{class: "text-[10px] tracking-[0.2em]"}
            = t(".platform")
          %ul.flex.flex-col.gap-4
            %li
              = link_to t(".all_courses"), courses_path, class: "text-sm font-bold uppercase text-neutral-900 hover:underline decoration-2 underline-offset-4 transition-all"
            %li
              = link_to t(".for_companies"), courses_path, class: "text-sm font-bold uppercase text-neutral-900 hover:underline decoration-2 underline-offset-4 transition-all"

        .p-6.md:p-12.border-b.sm:border-b-0.sm:border-r.border-neutral-900.flex.flex-col
          %span.block.font-bold.uppercase.text-neutral-400.mb-8{class: "text-[10px] tracking-[0.2em]"}
            = t(".company")
          %ul.flex.flex-col.gap-4
            %li
              = link_to t(".about_us"), root_path, class: "text-sm font-bold uppercase text-neutral-900 hover:underline decoration-2 underline-offset-4 transition-all"
            %li
              = link_to t(".career"), root_path, class: "text-sm font-bold uppercase text-neutral-900 hover:underline decoration-2 underline-offset-4 transition-all"
            %li
              = link_to t(".manifest"), root_path, class: "text-sm font-bold uppercase text-neutral-900 hover:underline decoration-2 underline-offset-4 transition-all"
            %li
              = link_to t(".contact"), root_path, class: "text-sm font-bold uppercase text-neutral-900 hover:underline decoration-2 underline-offset-4 transition-all"

        .p-6.md:p-12.flex.flex-col
          %span.block.font-bold.uppercase.text-neutral-400.mb-8{class: "text-[10px] tracking-[0.2em]"}
            = t(".network")
          %ul.flex.flex-col.gap-4
            %li.flex
              = link_to root_path, class: "group flex items-center text-sm font-bold uppercase text-neutral-900 transition-all" do
                %span.group-hover:underline.decoration-2.underline-offset-4
                  = t(".github")
                %span.ml-2.opacity-0.-translate-x-2.group-hover:opacity-100.group-hover:translate-x-0.transition-all &nearr;
            %li.flex
              = link_to root_path, class: "group flex items-center text-sm font-bold uppercase text-neutral-900 transition-all" do
                %span.group-hover:underline.decoration-2.underline-offset-4
                  = t(".twitter")
                %span.ml-2.opacity-0.-translate-x-2.group-hover:opacity-100.group-hover:translate-x-0.transition-all &nearr;
            %li.flex
              = link_to root_path, class: "group flex items-center text-sm font-bold uppercase text-neutral-900 transition-all" do
                %span.group-hover:underline.decoration-2.underline-offset-4
                  = t(".linkedin")
                %span.ml-2.opacity-0.-translate-x-2.group-hover:opacity-100.group-hover:translate-x-0.transition-all &nearr;

    .border-t.border-neutral-900.bg-neutral-900.text-white.p-6.md:p-12.overflow-hidden.flex.items-center.justify-center
      %h1.font-black.uppercase.tracking-tighter.text-center.select-none{class: "text-[15vw] leading-[0.75] opacity-90"}
        = Constants::APPLICATION_NAME

    .border-t.border-neutral-900.bg-neutral-50.px-6.py-4.md:px-12.flex.flex-col.sm:flex-row.items-center.justify-between.gap-4

      %p.text-neutral-500.font-bold.uppercase{class: "text-[10px] tracking-widest"}
        &copy; #{Time.current.year} #{Constants::APPLICATION_NAME}. #{t(".all_rights_reserved")}

      .flex.items-center.gap-6
        %a.text-neutral-500.hover:text-neutral-900.font-bold.uppercase.transition-colors{href: "#", class: "text-[10px] tracking-widest"}
          = t(".regulations")
        %a.text-neutral-500.hover:text-neutral-900.font-bold.uppercase.transition-colors{href: "#", class: "text-[10px] tracking-widest"}
          = t(".privacy_policy")
