%header.w-full.flex.items-center.justify-between.px-6.md:px-12.h-24.z-50.relative{class: "bg-[#faf7f6]"}

  .flex.items-center.gap-10
    %a.text-3xl.tracking-normal.transition-opacity.hover:opacity-80{href: "/", class: "text-[#5a2e35]"}
      = Constants::APPLICATION_NAME

    %nav.hidden.lg:flex.items-center.gap-10
      = render Ui::NavLinkComponent.new(label: t(".courses"), href: courses_path)
      = render Ui::NavLinkComponent.new(label: t(".projects"), href: page_path("projects"))
      = render Ui::NavLinkComponent.new(label: t(".manifesto"), href: page_path("manifesto"))
      - if user&.teacher?
        = render Ui::NavLinkComponent.new(label: t(".instructor_dashboard"), href: teach_dashboard_path)

  .flex.items-center.gap-4
    %form.hidden.lg:flex.items-center.gap-2.rounded-full.px-4.py-2.transition-colors{action: courses_path, method: :get, class: "bg-white border border-[#f5e6e8] hover:border-[#e9d5d8] focus-within:border-[#e9d5d8]"}
      = lucide_icon("search", class: "w-4 h-4 flex-shrink-0 text-[#8a7b7e]")
      %input.bg-transparent.outline-none.text-sm.w-80{type: "search", name: "query", placeholder: t(".search_placeholder"), class: "placeholder:text-[#c4b0b3] text-[#5a2e35]"}

    - if user
      .relative{"data-controller": "user-menu", "data-action": "click@window->user-menu#close"}
        %button.overflow-hidden.transition-transform.hover:scale-105.rounded-full{class: "w-10 h-10 ring-2 ring-transparent hover:ring-[#e9d5d8]", "data-action": "click->user-menu#toggle"}
          = image_tag user.avatar_preview, class: "w-full h-full object-cover", alt: user.full_name

        .hidden.absolute.right-0.top-full.mt-3.w-48.rounded-xl.border.overflow-hidden.z-50{class: "bg-white border-[#f5e6e8] shadow-[0_8px_30px_rgba(0,0,0,0.04)]", "data-user-menu-target": "menu"}
          = link_to t(".profile"), edit_user_registration_path, class: "flex items-center gap-2 px-4 py-3 text-sm transition-colors text-[#5a2e35] hover:bg-[#faf7f6]"
          .border-t{class: "border-[#f5e6e8]"}
          = link_to t(".sign_out"), destroy_user_session_path, data: { turbo_method: :delete }, class: "flex items-center gap-2 px-4 py-3 text-sm transition-colors text-[#8a7b7e] hover:bg-[#faf7f6] hover:text-[#5a2e35]"

    - else
      = link_to t(".sign_in"), new_user_session_path, class: "uppercase tracking-widest text-[13px] font-medium text-[#8a7b7e] hover:text-[#5a2e35] transition-colors"

      = link_to new_user_registration_path, class: "transition-colors px-6 py-2.5 rounded-full flex items-center gap-2 bg-[#f5e6e8] hover:bg-[#e9d5d8] text-[#5a2e35] text-sm font-medium shadow-sm" do
        %span= t(".sign_up")
        = lucide_icon("arrow-right", class: "w-4 h-4")
