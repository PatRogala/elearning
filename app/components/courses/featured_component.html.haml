%section.w-full.px-6.md:px-12.py-20.lg:py-32{class: "bg-white"}

  .max-w-7xl.mx-auto
    .grid.grid-cols-1.lg:grid-cols-12.gap-16.lg:gap-12.items-center

      .lg:col-span-5.flex.flex-col.justify-center
        .mb-6
          %span.text-xs.font-medium.tracking-wide{class: "text-[#8d969e]"}
            = t('.header')

        %h1.font-medium.tracking-tight.mb-6{class: "text-[#191c1f] text-5xl lg:text-7xl leading-[1.05]"}
          %span.block
            = title
          %span.block{class: "text-[#505a63]"}
            = subtitle

        %p.text-base.mb-10.max-w-md{class: "text-[#505a63] leading-[1.56] tracking-[0.24px]"}
          = course.short_description

        .flex.flex-col.sm:flex-row.items-center.gap-4
          = link_to course_path(course), class: "w-full sm:w-auto flex items-center justify-center px-8 py-3.5 text-sm font-medium transition-opacity hover:opacity-85 rounded-full text-white bg-[#191c1f]" do
            = t('.cta')

      .lg:col-span-7.relative.mt-12.lg:mt-0
        .relative.w-full.overflow-hidden{class: "rounded-[20px] aspect-video"}
          = image_tag course.image_cover, class: "w-full h-full object-cover", alt: course.title

        .absolute.z-20.p-6.md:p-8{class: "-left-4 md:-left-12 -bottom-8 md:-bottom-12 w-[280px] md:w-[320px] bg-white border border-[#c9c9cd] rounded-xl"}
          .flex.items-center.gap-2.mb-3
            %span.w-2.h-2.rounded-full{class: "bg-[#191c1f]"}
            %span.text-xs.font-medium.tracking-wide{class: "text-[#8d969e]"}
              = t('.course_stats')

          %h3.text-base.font-medium.leading-snug.mb-2{class: "text-[#191c1f]"}
            = course.title

          %p.text-xs{class: "text-[#505a63] tracking-[0.16px]"}
            = t('.duration_info', duration: k(course).formatted_total_time_to_complete)
