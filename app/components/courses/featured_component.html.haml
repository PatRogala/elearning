%section.relative.w-full.overflow-hidden.px-6.md:px-12.py-20.lg:py-32{class: "bg-[#faf7f6] font-sans"}

  .absolute.rounded-full.pointer-events-none.-top-40.-left-40{class: "bg-[#f5e6e8] blur-[120px] opacity-60 w-[800px] h-[800px]"}
  .absolute.rounded-full.pointer-events-none.bottom-0.right-0{class: "bg-[#f8f4f2] blur-[100px] opacity-80 w-[600px] h-[600px]"}

  .max-w-7xl.mx-auto.relative.z-10
    .grid.grid-cols-1.lg:grid-cols-12.gap-16.lg:gap-12.items-center

      .lg:col-span-5.flex.flex-col.justify-center
        .mb-6
          %span.font-semibold.uppercase.tracking-widest{class: "text-[#cbb3b6] text-[10px]"}
            = t('.header')

        %h1.text-5xl.lg:text-7xl.font-light.tracking-tight.mb-6{class: "text-[#333333] leading-[1.1]"}
          %span.block
            = title
          %span.block.italic{class: "text-[#675458]"}
            = subtitle

        %p.text-base.leading-relaxed.mb-10.max-w-md{class: "text-[#8a7b7e]"}
          = course.short_description

        .flex.flex-col.sm:flex-row.items-center.gap-6
          = link_to course_path(course), class: "w-full sm:w-auto flex items-center justify-center px-8 py-4 text-sm font-medium transition-all shadow-sm hover:shadow-md rounded-xl text-white bg-[#675458] hover:bg-[#5a2e35]" do
            = t('.cta')

      .lg:col-span-7.relative.mt-12.lg:mt-0
        .relative.w-full.overflow-hidden{class: "rounded-[2.5rem] shadow-[0_20px_60px_rgba(103,84,88,0.08)] aspect-video"}
          = image_tag course.image_cover, class: "w-full h-full object-cover scale-105", alt: course.title

        .absolute.z-20.p-6.md:p-8.backdrop-blur-xl{class: "-left-4 md:-left-12 -bottom-8 md:-bottom-12 w-[280px] md:w-[320px] bg-white/70 border border-white/60 shadow-[0_8px_30px_rgba(0,0,0,0.04)] rounded-[2rem]"}
          .flex.items-center.gap-2.mb-3
            %span.w-2.h-2.rounded-full{class: "bg-[#675458]"}
            %span.uppercase.tracking-widest.font-semibold{class: "text-[#8a7b7e] text-[10px]"}
              = t('.course_stats')

          %h3.text-lg.font-medium.leading-snug.mb-2{class: "text-[#333333]"}
            = course.title

          %p.text-xs{class: "text-[#8a7b7e]"}
            = t('.duration_info', duration: 43)
