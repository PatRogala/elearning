%section.relative.w-full.overflow-hidden.px-6.md:px-12.py-20.lg:py-32{class: "bg-[#131313]"}

  .absolute.inset-0.opacity-30.pointer-events-none{class: "bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-[#5B3F44]/10 via-[#131313] to-[#131313]"}

  .max-w-7xl.mx-auto.relative.z-10
    .grid.grid-cols-1.lg:grid-cols-12.gap-16.lg:gap-8.items-center
      .lg:col-span-5.flex.flex-col.justify-center

        .mb-8
          %span.inline-block.border.px-3.py-1.font-bold.uppercase.tracking-widest{class: "border-[#5B3F44]/40 text-[#E5E2E1]/60 text-[10px]"}
            = t('.header')

        %h1.font-black.tracking-tighter.mb-6{class: "text-5xl lg:text-7xl leading-[1.05]"}
          %span.block{class: "text-[#E5E2E1]"}
            = title
          %span.block{class: "text-[#E0115F]"}
            = subtitle

        %p.font-medium.leading-relaxed.mb-10.max-w-lg{class: "text-base text-[#E5E2E1]/70"}
          = course.description.to_plain_text.truncate(100)

        .flex.flex-col.sm:flex-row.items-center.gap-4

          = link_to course_path(course), class: "w-full sm:w-auto flex items-center justify-center gap-3 px-8 py-4 font-bold uppercase tracking-widest transition-colors rounded-sm shadow-[0_0_20px_rgba(224,17,95,0.15)] hover:shadow-[0_0_25px_rgba(224,17,95,0.25)] bg-[#E0115F] hover:bg-[#E0115F]/90 text-[#FFF8F8] text-sm" do
            = t('.cta')
            = lucide_icon('arrow-right')

      .lg:col-span-7.relative.mt-12.lg:mt-0
        .relative.w-full.group.overflow-hidden{class: "bg-[#0E0E0E] border-l-[3px] aspect-video border-[#E0115F] shadow-[0_20px_50px_rgba(0,0,0,0.5)]"}
          = image_tag course.image_cover, class: "w-full h-full object-cover grayscale opacity-60 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700", alt: course.title

          .absolute.inset-0.pointer-events-none{class: "bg-gradient-to-t from-[#131313] via-transparent to-transparent"}

        .absolute.z-20.p-6.md:p-8.border.rounded-sm.backdrop-blur-md{class: "-left-4 md:-left-12 -bottom-8 md:-bottom-12 bg-[#1C1B1B]/95 border-[#5B3F44]/20 shadow-[0_20px_40px_rgba(0,0,0,0.8)]"}
          %span.block.font-bold.uppercase.tracking-widest.mb-2{class: "text-[#E5E2E1]/50 text-[10px]"}
            Course Duration
          .flex.items-baseline.gap-2
            %span.font-mono.font-bold.tracking-tight{class: "text-[#E5E2E1] text-3xl md:text-4xl"}
              42.5
            %span.font-mono.font-bold{class: "text-[#E5E2E1] text-xl md:text-2xl"}
              hrs

  .max-w-7xl.mx-auto.px-6.md:px-12.mt-20.lg:mt-32
    .flex.flex-wrap.items-center.gap-6.font-mono.uppercase.tracking-widest{class: "text-[#5B3F44] text-[9px] opacity-70"}
      %span COMPILED: V7.1.3
      %span LATENCY: 24MS
      %span NODES: 1,402
