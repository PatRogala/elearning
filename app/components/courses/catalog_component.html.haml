.min-h-screen.py-20{class: "px-6 md:px-12 lg:py-32 bg-white font-sans"}

  .max-w-7xl.mx-auto

    .flex.flex-col.items-center.text-center.mb-16
      %span.block.font-semibold.uppercase.tracking-widest.mb-4{class: "text-[10px] text-[#8d969e]"}
        = t('.catalog_subtitle', default: 'Course Catalog')

      %h1.mb-10{class: "text-4xl md:text-6xl font-medium leading-none text-[#191c1f]", style: "letter-spacing: -0.48px"}
        = t('.title')
        %span.italic
          = t('.subtitle')

      = form_with url: courses_path, method: :get, class: "w-full max-w-2xl relative" do |f|
        = lucide_icon("search", class: "absolute left-6 top-1/2 -translate-y-1/2 w-5 h-5 text-[#c9c9cd]")
        = f.text_field :query, placeholder: t('.search_placeholder'), class: "w-full pl-14 pr-6 py-4 bg-[#f4f4f4] rounded-full border-0 text-sm text-[#191c1f] placeholder:text-[#8d969e] focus:outline-none focus:ring-2 focus:ring-[#191c1f]/10 transition-all"

    .flex.flex-wrap.items-center.justify-center.gap-3.mb-16
      %button.rounded-full.text-sm.font-medium.transition-all{type: "button", class: "bg-[#191c1f] text-white px-8 py-3.5 hover:opacity-85"}
        = t('.all_courses')

      %button.rounded-full.text-sm.font-medium.transition-all{type: "button", class: "bg-[#f4f4f4] text-[#191c1f] px-8 py-3.5 hover:opacity-85"}
        Ruby on Rails

      %button.rounded-full.text-sm.font-medium.transition-all{type: "button", class: "bg-[#f4f4f4] text-[#191c1f] px-8 py-3.5 hover:opacity-85"}
        React

      %button.rounded-full.text-sm.font-medium.transition-all{type: "button", class: "bg-[#f4f4f4] text-[#191c1f] px-8 py-3.5 hover:opacity-85"}
        UI/UX

    = turbo_frame_tag "courses_grid" do
      .grid.grid-cols-1.gap-8{class: "md:grid-cols-2 lg:grid-cols-3"}
        - courses.each do |course|
          = render Courses::CardComponent.new(course)

    .flex.items-center.justify-center.gap-2.mt-20
      %button.flex.items-center.justify-center.w-10.h-10.rounded-full.transition-all{disabled: true, class: "bg-[#f4f4f4] text-[#c9c9cd] cursor-not-allowed"}
        = lucide_icon("chevron-left", class: "w-4 h-4")

      %span.flex.items-center.justify-center.w-10.h-10.rounded-full.text-sm.font-medium{class: "bg-[#191c1f] text-white"}
        1

      %a.flex.items-center.justify-center.w-10.h-10.rounded-full.text-sm.font-medium.transition-all{href: "#", class: "bg-[#f4f4f4] text-[#191c1f] hover:opacity-85"}
        2

      %a.flex.items-center.justify-center.w-10.h-10.rounded-full.transition-all{href: "#", class: "bg-[#f4f4f4] text-[#191c1f] hover:opacity-85"}
        = lucide_icon("chevron-right", class: "w-4 h-4")
