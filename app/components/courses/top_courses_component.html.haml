%section.w-full.relative{class: "bg-[#131313] py-20 lg:py-32 px-6 md:px-12"}
  .max-w-7xl.mx-auto
    .flex.flex-col.sm:flex-row.sm:items-end.justify-between.gap-6.mb-12.lg:mb-16

      .relative.pb-4
        %h2.font-black.tracking-tight{class: "text-[#E5E2E1] text-3xl md:text-4xl"}
          = t(".top_courses")
        .absolute.bottom-0.left-0.h-1.w-12{class: "bg-[#E0115F]"}

      = link_to courses_path, class: "group flex items-center gap-2 font-mono uppercase tracking-widest transition-colors text-[#E5E2E1]/50 hover:text-[#E5E2E1] text-[10px]" do
        = t(".browse_all_modules")
        = lucide_icon("external-link", class: "w-3 h-3")


    .grid.grid-cols-1.md:grid-cols-2.lg:grid-cols-3.gap-x-8.gap-y-12

      - courses.each do |course|

        = link_to course_path(course), class: "group flex flex-col" do
          .relative.w-full.overflow-hidden.rounded-sm.border{class: "aspect-video bg-[#1C1B1B] border-[#5B3F44]/20 shadow-[0_10px_30px_rgba(0,0,0,0.5)]"}
            = image_tag course.image_cover, class: "w-full h-full object-cover grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700"

            .absolute.top-3.left-3.backdrop-blur-md.border.px-2.py-1{class: "bg-[#0E0E0E]/80 border-[#5B3F44]/40"}
              %span.font-mono.uppercase.tracking-widest{class: "text-[#E5E2E1]/80 text-[9px]"}
                = "Backend"

          %h3.mt-5.font-bold.transition-colors.leading-tight{class: "text-[#E5E2E1] text-lg md:text-xl group-hover:text-[#E0115F]"}
            = course.title

          .mt-3.flex.items-center.justify-between{class: "text-[#E5E2E1]/50"}

            .flex.items-center.gap-1.font-mono.uppercase.tracking-widest{class: "text-[9px]"}
              %span.opacity-60
                = t(".instructor")
              %span{class: "text-[#E5E2E1]"}= course.instructor.full_name

            .flex.items-center.gap-1.font-mono{class: "text-[10px]"}
              = lucide_icon("star", class: "w-3 h-3 translate-y-[-1px] text-[#E0115F]", fill: "currentColor")
              %span.font-bold{class: "text-[#E5E2E1]"} 5
