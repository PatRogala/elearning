%section.w-full.relative{class: "bg-[#131313] py-20 lg:py-32 px-6 md:px-12"}
  .max-w-7xl.mx-auto
    .flex.flex-col.sm:flex-row.sm:items-end.justify-between.gap-6.mb-12.lg:mb-16

      .relative.pb-4
        %h2.font-black.tracking-tight{class: "text-[#E5E2E1] text-3xl md:text-4xl"}
          Top Courses
        .absolute.bottom-0.left-0.h-1.w-12{class: "bg-[#E0115F]"}

      -# Link do wszystkich modułów
      %a.group.flex.items-center.gap-2.font-mono.uppercase.tracking-widest.transition-colors{href: "#", class: "text-[#E5E2E1]/50 hover:text-[#E5E2E1] text-[10px]"}
        Browse All Modules
        -# Ikonka zewnętrznego linku / wchodzenia do folderu
        %svg.w-3.h-3.transition-transform.group-hover:-translate-y-0.5.group-hover:translate-x-0.5{fill: "none", stroke: "currentColor", "stroke-width" => "2", viewBox: "0 0 24 24"}
          %path{d: "M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"}
          %polyline{points: "15 3 21 3 21 9"}
          %line{x1: "10", y1: "14", x2: "21", y2: "3"}

    -# --- GRID KURSÓW ---
    -# Definiujemy 3 kolumny na dużych ekranach, 2 na średnich
    .grid.grid-cols-1.md:grid-cols-2.lg:grid-cols-3.gap-x-8.gap-y-12

      -# Pętla z mockowanymi danymi (zastąp to własnym @courses.each)
      - [ { title: "Full-Stack Javascript", tag: "JS.CORE", inst: "Elias Thorne", rating: "4.9", img: "https://via.placeholder.com/800x450/1C1B1B/393939?text=JS" },
          { title: "DevOps Fundamentals", tag: "OPS.01", inst: "Sarah Chen", rating: "4.8", img: "https://via.placeholder.com/800x450/1C1B1B/393939?text=Ops" },
          { title: "Machine Learning with Python", tag: "ML.PY", inst: "Dr. Marcus Vane", rating: "5.0", img: "https://via.placeholder.com/800x450/1C1B1B/393939?text=Guonation" },
          { title: "React Patterns & Scale", tag: "UI.CORE", inst: "Lena Rivers", rating: "4.7", img: "https://via.placeholder.com/800x450/1C1B1B/393939?text=React" },
          { title: "Kubernetes for Architects", tag: "SYS.CLD", inst: "Aris Thorne", rating: "4.9", img: "https://via.placeholder.com/800x450/1C1B1B/393939?text=Cloud" },
          { title: "Advanced Security Systems", tag: "SEC.01", inst: "Cipher X", rating: "4.8", img: "https://via.placeholder.com/800x450/1C1B1B/393939?text=Security" } ].each do |course|

        -# --- POJEDYNCZA KARTA (Cała klikalna) ---
        %a.group.flex.flex-col{href: "#"}

          -# 1. Thumbnail (16:9, Zaokrąglenie 'sm', Grayscale hover)
          -# Obramowanie w "Ghost Border" dla delikatnego odcięcia od czerni
          .relative.w-full.overflow-hidden.rounded-sm.border{class: "aspect-video bg-[#1C1B1B] border-[#5B3F44]/20 shadow-[0_10px_30px_rgba(0,0,0,0.5)]"}

            %img.w-full.h-full.object-cover.grayscale.opacity-80.group-hover:grayscale-0.group-hover:opacity-100.group-hover:scale-105.transition-all.duration-700{src: course[:img], alt: course[:title]}

            -# Terminal Badge (Z lewej u góry)
            .absolute.top-3.left-3.backdrop-blur-md.border.px-2.py-1{class: "bg-[#0E0E0E]/80 border-[#5B3F44]/40"}
              %span.font-mono.uppercase.tracking-widest{class: "text-[#E5E2E1]/80 text-[9px]"}
                = course[:tag]

          -# 2. Tytuł kursu
          %h3.mt-5.font-bold.transition-colors.leading-tight{class: "text-[#E5E2E1] text-lg md:text-xl group-hover:text-[#E0115F]"}
            = course[:title]

          -# 3. Metadane (Stopka karty)
          .mt-3.flex.items-center.justify-between{class: "text-[#E5E2E1]/50"}

            -# Instruktor
            .flex.items-center.gap-1.font-mono.uppercase.tracking-widest{class: "text-[9px]"}
              %span.opacity-60 Inst:
              %span{class: "text-[#E5E2E1]"}= course[:inst]

            -# Ocena
            .flex.items-center.gap-1.font-mono{class: "text-[10px]"}
              %svg.w-3.h-3{class: "translate-y-[-1px] text-[#E0115F]", fill: "currentColor", viewBox: "0 0 20 20"}
                %path{d: "M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"}
              %span.font-bold{class: "text-[#E5E2E1]"}
                = course[:rating]
