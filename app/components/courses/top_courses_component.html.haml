%section.relative.w-full.px-6.py-20{class: "md:px-12 lg:py-32 bg-[#faf7f6] font-sans"}
  .max-w-7xl.mx-auto

    .flex.flex-col.justify-between.gap-6.mb-16{class: "md:flex-row md:items-end"}
      .max-w-2xl
        %span.block.font-semibold.uppercase.tracking-widest.mb-4{class: "text-[10px] text-[#8a7b7e]"}
          = t('.newest_courses')
        %h2.text-4xl.font-light.tracking-tight.leading-tight{class: "md:text-5xl text-[#333333]"}
          = t('.title')

      %div
        = link_to courses_path, class: "flex items-center gap-2 text-sm font-medium pb-1 border-b transition-colors text-[#675458] border-[#e9d5d8] hover:border-[#675458]" do
          = t('.browse_all_modules')
          = lucide_icon('arrow-right', class: 'w-4 h-4')

    .grid.grid-cols-1.gap-8{class: "md:grid-cols-2 lg:grid-cols-3"}
      - @courses.each do |course|

        .group.flex.flex-col.bg-white.transition-shadow.duration-300.p-3{class: "rounded-[2rem] shadow-[0_8px_30px_rgba(0,0,0,0.03)] hover:shadow-[0_20px_50px_rgba(103,84,88,0.08)]"}

          .relative.w-full.overflow-hidden{class: "aspect-[16/9] rounded-[1.5rem] bg-[#f5e6e8]"}
            = image_tag course.image_cover, class: "w-full h-full object-cover transition-transform duration-700 scale-105", alt: course.title
            .absolute.top-4.left-4.px-3.py-1.5.backdrop-blur-md.rounded-full{class: "bg-white/70 shadow-sm"}
              %span.font-bold.uppercase.tracking-widest{class: "text-[9px] text-[#5a2e35]"}
                = 'Backend'

          .p-5.flex.flex-col.flex-grow{class: "md:p-6"}

            -# TODO: Add modules and difficulty
            -# .flex.items-center.gap-2.mb-3.font-semibold.uppercase.tracking-widest{class: "text-[9px] text-[#8a7b7e]"}
            -#   %span= "#{12} MODULES"
            -#   %span.w-1.h-1.rounded-full{class: "bg-[#e9d5d8]"}
            -#   %span= 'ADVANCED'

            %h3.text-xl.font-medium.mb-3.line-clamp-2{class: "text-[#333333]"}
              = course.title

            %p.text-sm.leading-relaxed.line-clamp-2.mb-8.flex-grow{class: "text-[#8a7b7e]"}
              = course.description.to_plain_text.truncate(120)

            .mt-auto.flex.flex-col.gap-5

              .flex.items-center.gap-3.pt-5.border-t{class: "border-[#f5e6e8]"}
                = image_tag course.instructor.avatar_preview, class: "w-9 h-9 rounded-full object-cover bg-[#f5e6e8]"

                .flex.flex-col
                  %span.uppercase.tracking-widest{class: "text-[9px] text-[#8a7b7e]"}
                    = t('.instructor')
                  %span.font-medium{class: "text-[11px] text-[#333333]"}
                    = course.instructor.full_name

              = link_to course_path(course), class: "w-full py-3.5 flex items-center justify-center transition-colors rounded-xl text-sm font-medium bg-[#faf7f6] hover:bg-[#e9d5d8] text-[#5a2e35]" do
                = t('.start_learning')
