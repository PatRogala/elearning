.min-h-screen{class: "bg-white font-sans"}

  .max-w-7xl.mx-auto.relative{class: "px-6 md:px-10 py-6 md:py-10"}

    .flex.items-center.gap-2.mb-8.font-semibold.uppercase.tracking-widest{class: "text-[10px] text-[#8d969e]"}
      = link_to t('.index'), courses_path, class: "hover:text-[#191c1f] transition-colors"
      %span.opacity-40 /
      %span.transition-colors{class: "cursor-default text-[#191c1f]"}= course.title

    .grid.grid-cols-1.gap-6{class: "lg:grid-cols-12"}

      .space-y-6{class: "lg:col-span-8"}

        .overflow-hidden{class: "rounded-[1.25rem] bg-[#f4f4f4]"}

          .relative.w-full.overflow-hidden.group{class: "aspect-video bg-[#f4f4f4]"}
            = image_tag course.image_cover, class: "w-full h-full object-cover scale-105 transition-all duration-700"

            .absolute.bottom-4.left-4.flex.items-center.gap-2
              %span.px-3.py-1.rounded-full.text-xs.font-semibold.uppercase.tracking-widest{class: "bg-white text-[#191c1f]"} Backend
              %span.px-3.py-1.rounded-full.text-xs.font-semibold.uppercase.tracking-widest{class: "bg-[#191c1f] text-white"} Bestseller

          .p-8{class: "md:p-10"}
            %h1.text-4xl.font-medium.tracking-tight.leading-tight.mb-4{class: "md:text-5xl text-[#191c1f]", style: "letter-spacing: -0.4px"}
              = course.title

            .flex.flex-wrap.items-center.gap-4
              .flex.items-center.gap-1.5
                = lucide_icon("star", class: "w-4 h-4 fill-amber-400 stroke-amber-400")
                %span.text-sm.font-semibold{class: "text-[#191c1f]"} 4.9
                %span.text-sm{class: "text-[#8d969e]"} (128 opinii)
              .w-px.h-4{class: "bg-[#c9c9cd]"}
              .flex.items-center.gap-1.5
                = lucide_icon("users", class: "w-4 h-4 stroke-[1.5] text-[#8d969e]")
                %span.text-sm{class: "text-[#505a63]"} 1 240 uczestników
              .w-px.h-4{class: "bg-[#c9c9cd]"}
              .flex.items-center.gap-1.5
                = lucide_icon("clock", class: "w-4 h-4 stroke-[1.5] text-[#8d969e]")
                %span.text-sm{class: "text-[#505a63]"}
                  = k(course).formatted_total_time_to_complete

        .p-8{class: "md:p-10 rounded-[1.25rem] bg-[#f4f4f4]"}
          %h2.text-xl.font-medium.tracking-tight.mb-6{class: "text-[#191c1f]"}
            = t('.about_the_course')
          .prose.prose-sm.max-w-none.leading-relaxed{class: "text-[#505a63]"}
            = course.description

        .p-8{class: "md:p-10 rounded-[1.25rem] bg-[#f4f4f4]"}
          %h2.text-xl.font-medium.tracking-tight.mb-6{class: "text-[#191c1f]"}
            = t('.what_you_will_learn')
          .grid.grid-cols-1.gap-4{class: "sm:grid-cols-2"}
            - [["Autoryzacja JWT", "Bezpieczne logowanie i odświeżanie tokenów bez ciężkich gemów.", "shield-check"], ["N+1 Queries", "Narzędzia i techniki eliminacji problemów z wydajnością PostgreSQL.", "zap"], ["REST API Design", "Konwencje i dobre praktyki projektowania czytelnych endpointów.", "layers"], ["Testy RSpec", "Pisanie testów integracyjnych i jednostkowych dla API.", "check-circle"]].each do |(title, desc, icon)|
              .flex.items-start.gap-4.p-5.rounded-2xl{class: "bg-white"}
                .w-9.h-9.rounded-xl.flex.items-center.justify-center.shrink-0{class: "bg-[#f4f4f4]"}
                  = lucide_icon(icon, class: "w-5 h-5 stroke-[1.5] text-[#191c1f]")
                .space-y-1
                  %h3.text-sm.font-semibold{class: "text-[#191c1f]"}= title
                  %p.text-xs.leading-relaxed{class: "text-[#505a63]"}= desc

        .overflow-hidden{class: "rounded-[1.25rem] bg-[#f4f4f4]"}
          .p-8.flex.items-start.justify-between{class: "md:p-10 pb-6! md:pb-6!"}
            %div
              %h2.text-xl.font-medium.tracking-tight{class: "text-[#191c1f]"}
                = t('.program')
              %p.text-xs.font-semibold.uppercase.tracking-widest.mt-1{class: "text-[#8d969e]"}
                = t('.lessons_count', count: course.lessons.count)

          -# TODO: Add modules
          -# .px-8.py-3.border-y{class: "md:px-10 bg-white border-[#c9c9cd]"}
          -#   %h3.text-xs.font-semibold.uppercase.tracking-widest{class: "text-[#191c1f]"} Moduł 01: Fundamenty API

          - ordered_lessons = course.lessons.ordered
          %div{"data-controller": "lesson-list"}
            .divide-y{class: "divide-[#c9c9cd]"}
              - ordered_lessons.first(2).each do |lesson|
                .flex.items-center.justify-between.px-8.py-4{class: "md:px-10"}
                  .flex.items-center.gap-4
                    .w-8.h-8.rounded-lg.flex.items-center.justify-center.shrink-0{class: "bg-white"}
                      = lucide_icon("lock", class: "w-4 h-4 stroke-[1.5] text-[#c9c9cd]")
                    %span.text-sm{class: "text-[#505a63]"}
                      = lesson.title
                  %span.text-xs.font-semibold{class: "text-[#8d969e]"}
                    = k(lesson).formatted_time_to_complete
              - if ordered_lessons.count > 2
                %div.hidden{"data-lesson-list-target": "hidden"}
                  - ordered_lessons.drop(2).each do |lesson|
                    .flex.items-center.justify-between.px-8.py-4.border-t{class: "md:px-10 border-[#c9c9cd]"}
                      .flex.items-center.gap-4
                        .w-8.h-8.rounded-lg.flex.items-center.justify-center.shrink-0{class: "bg-white"}
                          = lucide_icon("lock", class: "w-4 h-4 stroke-[1.5] text-[#c9c9cd]")
                        %span.text-sm{class: "text-[#505a63]"}
                          = lesson.title
                      %span.text-xs.font-semibold{class: "text-[#8d969e]"}
                        = k(lesson).formatted_time_to_complete

            - if ordered_lessons.count > 2
              .px-8.py-5.border-t{class: "md:px-10 border-[#c9c9cd]", "data-lesson-list-target": "button"}
                %button.inline-flex.items-center.gap-2.text-sm.font-medium.transition-colors{type: "button", class: "text-[#191c1f] hover:opacity-70", "data-action": "lesson-list#show"}
                  = lucide_icon("chevron-down", class: "w-4 h-4 stroke-[2]")
                  = t('.show_all_lessons', count: course.lessons.count)

        .p-8{class: "md:p-10 rounded-[1.25rem] bg-[#f4f4f4]"}
          %h2.text-xl.font-medium.tracking-tight.mb-6{class: "text-[#191c1f]"}
            = t('.instructor')
          .flex.flex-col.items-start.gap-6{class: "sm:flex-row"}
            .w-20.h-20.rounded-2xl.overflow-hidden.shrink-0.border{class: "border-[#c9c9cd]"}
              = image_tag instructor.avatar_preview, class: "w-full h-full object-cover"
            %div
              %h3.text-lg.font-medium{class: "text-[#191c1f]"}= instructor.full_name
              %span.block.text-xs.font-semibold.uppercase.tracking-widest.mb-3{class: "text-[#8d969e]"} Senior Backend Developer
              %p.text-sm.leading-relaxed{class: "text-[#505a63]"}= instructor.bio


      .relative{class: "lg:col-span-4"}
        .sticky{class: "top-8 space-y-4"}

          .overflow-hidden{class: "rounded-[1.25rem] bg-[#f4f4f4]"}

            .p-6.space-y-6{class: "md:p-8"}

              - if course.price.zero?
                .space-y-1
                  %p.font-semibold.uppercase.tracking-widest{class: "text-[10px] text-[#8d969e]"}
                    = t('.access')
                  .flex.items-baseline.gap-2
                    %span.text-4xl.font-medium.tracking-tight{class: "text-[#191c1f]"}
                      = t('.free')
              - else
                .space-y-1
                  %p.font-semibold.uppercase.tracking-widest{class: "text-[10px] text-[#8d969e]"}= t('.investment')
                  .flex.items-baseline.gap-2
                    %span.text-5xl.font-medium.tracking-tight{class: "text-[#191c1f]"}= course.price
                    %span.text-xl.font-medium.pb-1{class: "text-[#191c1f]"}= course.price.currency.symbol

              - if course.price.zero?
                - if enrolled
                  .w-full.flex.items-center.justify-between.px-6.py-4.rounded-full.text-sm.font-semibold{class: "bg-[#f4f4f4] text-[#505a63]"}
                    %span= t('.already_enrolled')
                    = lucide_icon("check-circle", class: "w-5 h-5 stroke-[2] shrink-0")
                - else
                  = helpers.form_with(url: helpers.course_enrollments_path(course), method: :post) do |f|
                    %button.w-full.flex.items-center.justify-between.px-6.py-4.rounded-full.text-sm.font-semibold.transition-all.group{type: "submit", class: "bg-[#191c1f] hover:opacity-85 text-white"}
                      %span
                        = t('.sign_up_now_for_free')
                      = lucide_icon("arrow-right", class: "w-5 h-5 stroke-[2] transition-transform group-hover:translate-x-1 shrink-0")
                .flex.items-center.justify-center.gap-2.pt-1
                  = lucide_icon("check-circle", class: "w-4 h-4 stroke-[1.5] text-[#8d969e]")
                  %p.text-xs.font-medium{class: "text-[#505a63]"}
                    = t('.instant_access_guarantee')
              - else
                %form{action: "#", method: "post"}
                  %button.w-full.flex.items-center.justify-between.px-6.py-4.rounded-full.text-sm.font-semibold.transition-all.group{type: "submit", class: "bg-[#191c1f] hover:opacity-85 text-white"}
                    %span= t('.buy_access')
                    = lucide_icon("arrow-right", class: "w-5 h-5 stroke-[2] transition-transform group-hover:translate-x-1 shrink-0")
                .flex.items-center.justify-center.gap-2.pt-1
                  = lucide_icon("shield-check", class: "w-4 h-4 stroke-[1.5] text-[#8d969e]")
                  %p.text-xs.font-medium{class: "text-[#505a63]"}= t('.lifetime_access')

              .space-y-3.pt-2.border-t{class: "border-[#c9c9cd]"}
                %p.text-xs.font-semibold.uppercase.tracking-widest{class: "text-[#8d969e]"}
                  = t('.what_you_will_receive')
                - [["play-circle", t('.all_lessons_access')], ["code-2", t('.exercises_and_tasks')], ["message-circle", t('.community_access')], ["award", t('.yes_pdf')]].each do |(icon, label)|
                  .flex.items-center.gap-3
                    = lucide_icon(icon, class: "w-4 h-4 shrink-0 stroke-[1.5] text-[#8d969e]")
                    %span.text-sm{class: "text-[#505a63]"}= label

          .p-6{class: "rounded-[1.25rem] bg-[#f4f4f4] space-y-4"}
            .flex.items-center.justify-between
              %span.text-xs.font-semibold.uppercase.tracking-widest{class: "text-[#8d969e]"}= t('.level')
              %span.text-xs.font-medium{class: "text-[#191c1f]"} Średniozaawansowany
            .h-px{class: "bg-[#c9c9cd]"}
            .flex.items-center.justify-between
              %span.text-xs.font-semibold.uppercase.tracking-widest{class: "text-[#8d969e]"}= t('.language')
              %span.text-xs.font-medium{class: "text-[#191c1f]"} Polski
            .h-px{class: "bg-[#c9c9cd]"}
            .flex.items-center.justify-between
              %span.text-xs.font-semibold.uppercase.tracking-widest{class: "text-[#8d969e]"}= t('.certificate')
              .flex.items-center.gap-1.5
                = lucide_icon("file-text", class: "w-4 h-4 stroke-[1.5] text-[#8d969e]")
                %span.text-xs.font-medium{class: "text-[#191c1f]"}= t('.yes_pdf')

          .p-6{class: "rounded-[1.25rem] bg-[#f4f4f4]"}
            %p.text-xs.font-semibold.uppercase.tracking-widest.mb-3{class: "text-[#8d969e]"}= t('.technologies')
            .flex.flex-wrap.gap-2
              - ["Ruby 3.2", "Rails 8", "PostgreSQL", "RSpec", "JWT"].each do |tag|
                %span.px-3.py-1.rounded-full.text-xs.font-medium{class: "bg-white text-[#191c1f]"}= tag
