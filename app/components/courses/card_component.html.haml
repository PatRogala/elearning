%a.group.flex.flex-col.border.border-neutral-900.bg-white.hover:bg-neutral-50.transition-colors.duration-300{href: "#"}
  .relative.w-full.aspect-video.bg-neutral-100.border-b.border-neutral-900.overflow-hidden
    = image_tag course.image_cover, class: "w-full h-full object-cover group-hover:scale-105 transition-all duration-700"

  .p-6.flex-1.flex.flex-col
    .flex.items-center.justify-between.mb-4
      %span.px-2.py-0.5.border.border-neutral-300.font-bold.uppercase.text-neutral-600{class: "text-[9px]"} Ruby on Rails
      .flex.items-center.gap-1.text-neutral-400
        %svg.w-3.h-3{fill: "none", stroke: "currentColor", "stroke-width" => "2", viewBox: "0 0 24 24"}
          %path{d: "M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"}
        %span.font-bold.tracking-widest{class: "text-[10px]"} 12h 30m

    %h3.text-2xl.font-black.uppercase.tracking-tighter.text-neutral-900.mb-3.leading-none.group-hover:underline.decoration-2.underline-offset-4
      = title
      %span.inline-block.ml-2.opacity-0.-translate-x-2.group-hover:opacity-100.group-hover:translate-x-0.transition-all &rarr;

    .text-sm.text-neutral-600.mb-8.line-clamp-2.overflow-y-scroll.scrollbar-editorial{class: "h-[4.5rem]"}
      = description


    .mt-auto.pt-4.border-t.border-neutral-200.flex.items-center.justify-between

      .flex.items-center.gap-2
        .w-6.h-6.bg-neutral-200.border.border-neutral-900.overflow-hidden
          = image_tag instructor.avatar_preview, class: "w-full h-full object-cover"
        %span.font-bold.uppercase.tracking-widest.text-neutral-900{class: "text-[10px]"}
          = instructor.full_name

      %span.text-lg.font-black.text-neutral-900
        = course.price.format
