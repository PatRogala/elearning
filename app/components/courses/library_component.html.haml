%section.border-b.border-neutral-900.bg-white
  .border-b.border-neutral-900.p-6
    .flex.items-center.justify-between.max-w-7xl.mx-auto
      %h2.text-2xl.font-black.uppercase.tracking-tighter.text-neutral-900
        = t(".title")
      %a.text-xs.font-bold.uppercase.tracking-widest.text-neutral-900.hover:underline{href: "#"}
        = t(".see_all")
        &rarr;

  .max-w-7xl.mx-auto
    .grid.grid-cols-1.md:grid-cols-2.lg:grid-cols-3

      - courses.each do |course|
        = render Courses::CardComponent.new(course)
