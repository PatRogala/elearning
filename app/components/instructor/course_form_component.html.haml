.min-h-screen.py-20{class: "px-6 md:px-12 bg-white font-sans"}

  .max-w-2xl.mx-auto
    .mb-12.space-y-3
      %p.font-semibold.uppercase.tracking-widest{class: "text-[10px] text-[#8d969e]"}
        = t(".step_1")
      %h1.text-4xl.font-medium.tracking-tight.leading-tight{class: "md:text-5xl text-[#191c1f]"}
        = t(".give_your_new_course_a_working_title")

    = form_with(model: form, url: teach_courses_path, class: "block") do |f|

      .p-8.mb-6{class: "rounded-[20px] bg-[#f4f4f4]"}

        = f.label :title, class: "block font-semibold uppercase tracking-widest mb-4 text-[#8d969e]", style: "font-size: 10px" do
          = t(".course_title")

        = f.text_field :title,
          class: "block w-full text-2xl font-medium bg-transparent border-b-2 pb-3 text-[#191c1f] border-[#c9c9cd] placeholder:text-[#c9c9cd] focus:outline-none focus:border-[#191c1f] transition-colors",
          placeholder: t(".course_placeholder"),
          required: true,
          autofocus: true

        .mt-6.flex.items-start.gap-3
          = lucide_icon("info", class: "w-4 h-4 mt-0.5 shrink-0 stroke-[1.5] text-[#8d969e]")
          %p.text-sm.leading-relaxed{class: "text-[#505a63]"}
            = t(".helper_text")

      .flex.items-center.justify-between
        = link_to teach_dashboard_path, class: "inline-flex items-center justify-center rounded-full text-sm font-medium transition-opacity border text-[#191c1f] border-[#191c1f] hover:opacity-70", style: "padding: 14px 32px" do
          = t(".cancel")

        = f.button :submit, class: "group inline-flex items-center justify-center rounded-full text-sm font-medium transition-opacity text-white bg-[#191c1f] hover:opacity-85", style: "padding: 14px 32px" do
          = t(".create_and_continue")
          = lucide_icon("arrow-right", class: "w-4 h-4 ml-2 transition-transform group-hover:translate-x-1 stroke-[2]")
