.min-h-screen.relative.py-20{class: "px-6 md:px-12 bg-[#faf7f6] font-sans"}

  .absolute.rounded-full.pointer-events-none.top-0.-left-32{class: "bg-[#f5e6e8] blur-[120px] opacity-60 w-[600px] h-[600px]"}
  .absolute.rounded-full.pointer-events-none.-right-32{class: "top-[30%] bg-[#f8f4f2] blur-[100px] opacity-80 w-[500px] h-[500px]"}

  .max-w-2xl.mx-auto.relative.z-10

    -# --- HEADER ---
    .mb-12.space-y-3
      %p.font-semibold.uppercase.tracking-widest{class: "text-[10px] text-[#8a7b7e]"}
        = t(".step_1")
      %h1.text-4xl.font-light.tracking-tight.leading-tight{class: "md:text-5xl text-[#333333]"}
        %span.italic.font-normal{class: "text-[#675458]"}
          = t(".give_your_new_course_a_working_title")

    -# --- FORM ---
    = form_with(model: form, url: teach_courses_path, class: "block") do |f|

      .p-8.bg-white.mb-6{class: "rounded-[2rem] shadow-[0_8px_30px_rgba(0,0,0,0.03)]"}

        = f.label :title, class: "block font-semibold uppercase tracking-widest mb-4 text-[#cbb3b6]", style: "font-size: 10px" do
          = t(".course_title")

        = f.text_field :title,
          class: "block w-full text-2xl font-light bg-transparent border-b-2 pb-3 text-[#333333] border-[#f5e6e8] placeholder:text-[#e9d5d8] focus:outline-none focus:border-[#675458] transition-colors",
          placeholder: t(".course_placeholder"),
          required: true,
          autofocus: true

        .mt-6.flex.items-start.gap-3
          = lucide_icon("info", class: "w-4 h-4 mt-0.5 shrink-0 stroke-[1.5] text-[#cbb3b6]")
          %p.text-sm.leading-relaxed{class: "text-[#8a7b7e]"}
            = t(".helper_text")

      -# --- ACTIONS ---
      .flex.items-center.justify-between
        = link_to teach_dashboard_path, class: "inline-flex items-center justify-center px-8 py-4 rounded-xl text-sm font-medium transition-all border text-[#8a7b7e] border-[#e9d5d8] bg-white hover:border-[#c9a0a6] hover:text-[#5a2e35] hover:bg-[#fdf6f7] shadow-sm" do
          = t(".cancel")

        = f.button :submit, class: "group inline-flex items-center justify-center px-8 py-4 rounded-xl text-sm font-medium transition-all text-white shadow-sm hover:shadow-md bg-[#675458] hover:bg-[#5a2e35]" do
          = t(".create_and_continue")
          = lucide_icon("arrow-right", class: "w-4 h-4 ml-2 transition-transform group-hover:translate-x-1 stroke-[2]")
