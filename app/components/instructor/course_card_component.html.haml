= link_to edit_teach_course_path(course), class: "group flex flex-col bg-white transition-shadow duration-300 p-3 rounded-[2rem] shadow-[0_8px_30px_rgba(0,0,0,0.03)] hover:shadow-[0_20px_50px_rgba(103,84,88,0.08)]" do

  .relative.w-full.overflow-hidden{class: "aspect-[16/9] rounded-[1.5rem] bg-[#f5e6e8]"}
    = image_tag(course.image_cover, class: "w-full h-full object-cover transition-transform duration-700 scale-105")

    - if published?
      .absolute.top-4.left-4.px-3.py-1.5.backdrop-blur-md.rounded-full{class: "bg-white/80 shadow-sm"}
        %span.font-bold.uppercase.tracking-widest{class: "text-[9px] text-emerald-700"}
          = t(".published")
    - else
      .absolute.top-4.left-4.px-3.py-1.5.backdrop-blur-md.rounded-full{class: "bg-white/80 shadow-sm"}
        %span.font-bold.uppercase.tracking-widest{class: "text-[9px] text-[#8a7b7e]"}
          = t(".draft")

  .p-5.flex.flex-col.flex-grow{class: "md:p-6"}

    .flex.items-center.gap-2.mb-3.font-semibold.uppercase.tracking-widest{class: "text-[9px] text-[#8a7b7e]"}
      .flex.items-center.gap-1
        = lucide_icon("clock", class: "w-3 h-3 stroke-[2]")
        %span 4h 20m
      %span.w-1.h-1.rounded-full{class: "bg-[#e9d5d8]"}
      .flex.items-center.gap-1
        = lucide_icon("layout-list", class: "w-3 h-3 stroke-[2]")
        %span 12 lekcji

    %h3.text-xl.font-medium.mb-3.line-clamp-2.group-hover:underline.underline-offset-4.decoration-2{class: "text-[#333333] decoration-[#e9d5d8]"}
      = course.title

    %p.text-sm.leading-relaxed.line-clamp-2.mb-6.flex-grow{class: "text-[#8a7b7e]"}
      = short_description

    .mt-auto.pt-5.border-t.flex.items-center.justify-between{class: "border-[#f5e6e8]"}

      .flex.items-center.gap-4

        .flex.items-center.gap-1.5
          = lucide_icon("users", class: "w-3.5 h-3.5 stroke-[1.75]", style: "color: #cbb3b6")
          %span.font-medium{class: "text-[11px] text-[#8a7b7e]"}
            = students_count

        .flex.items-center.gap-1.5
          = lucide_icon("trending-up", class: "w-3.5 h-3.5 stroke-[1.75]", style: "color: #cbb3b6")
          %span.font-medium{class: "text-[11px] text-[#675458]"}
            4 200 zł

      %span.font-semibold.uppercase.tracking-widest.transition-colors{class: "text-[10px] text-[#675458] group-hover:text-[#5a2e35]"}
        = t(".manage")
        %span.inline-block.ml-0.5.opacity-0.-translate-x-1.transition-all{class: "group-hover:opacity-100 group-hover:translate-x-0"}
          &rarr;
