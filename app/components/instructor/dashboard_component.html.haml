.min-h-screen.py-12{class: "px-6 md:px-12 bg-white font-sans"}

  .max-w-7xl.mx-auto

    .flex.flex-col.justify-between.gap-6.mb-16{class: "md:flex-row md:items-end"}
      .space-y-3
        %p.font-semibold.uppercase.tracking-widest{class: "text-[10px] text-[#8d969e]"}
          = t(".overview")
        %h1.text-4xl.font-medium.tracking-tight.leading-tight{class: "md:text-5xl text-[#191c1f]"}
          = t(".welcome_back")
          %br
          %span.font-medium{class: "text-[#505a63]"}
            = user.full_name

      = link_to new_teach_course_path, class: "inline-flex items-center justify-center rounded-full text-sm font-medium transition-opacity text-white bg-[#191c1f] hover:opacity-85", style: "padding: 14px 32px" do
        = lucide_icon("plus", class: "w-4 h-4 mr-2")
        = t(".links.create_course")

    .grid.grid-cols-1.gap-6.mb-20{class: "md:grid-cols-3"}
      .p-8.flex.flex-col.gap-3{class: "rounded-[20px] bg-[#f4f4f4]"}
        %span.font-semibold.uppercase.tracking-widest{class: "text-[10px] text-[#8d969e]"}
          = t(".stats.total_courses")
        %span.text-4xl.font-medium{class: "text-[#191c1f]"}
          = created_courses_count

      .p-8.flex.flex-col.gap-3{class: "rounded-[20px] bg-[#f4f4f4]"}
        %span.font-semibold.uppercase.tracking-widest{class: "text-[10px] text-[#8d969e]"}
          = t(".stats.active_students")
        %span.text-4xl.font-medium{class: "text-[#191c1f]"}
          = active_students_count

      .p-8.flex.flex-col.gap-3{class: "rounded-[20px] bg-[#f4f4f4]"}
        %span.font-semibold.uppercase.tracking-widest{class: "text-[10px] text-[#8d969e]"}
          = t(".stats.revenue_ytd")
        %span.text-4xl.font-medium{class: "text-[#191c1f]"}
          = total_revenue

    .flex.items-center.justify-between.mb-10
      %h2.text-2xl.font-medium.tracking-tight{class: "text-[#191c1f]"}
        = t(".courses")

    - if courses.empty?
      .col-span-1{class: "md:col-span-2 lg:col-span-3"}
        = link_to new_teach_course_path, class: "group block w-full p-12 text-center transition-colors bg-[#f4f4f4] rounded-[20px] hover:bg-[#e8e8e8]" do
          .w-16.h-16.mx-auto.mb-6.rounded-full.flex.items-center.justify-center.transition-colors{class: "bg-white text-[#8d969e] group-hover:text-[#191c1f]"}
            = lucide_icon("plus", class: "w-6 h-6 stroke-[1.5]")

          %h3.text-xl.font-medium.mb-3{class: "text-[#191c1f]"}
            = t(".empty_state.headline")

          %p.text-sm.max-w-md.mx-auto.mb-6.leading-relaxed{class: "text-[#505a63]"}
            = t(".empty_state.subtext")

          %span.text-sm.font-medium.transition-opacity{class: "text-[#191c1f] group-hover:opacity-70"}
            = t(".links.create_course_now")

    - else
      .grid.grid-cols-1.gap-8{class: "md:grid-cols-2 lg:grid-cols-3"}
        - courses.each do |course|
          = render Instructor::CourseCardComponent.new(course)
