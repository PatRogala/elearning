.min-h-screen.relative.py-12{class: "px-6 md:px-12 bg-[#faf7f6] font-sans overflow-hidden"}

  .absolute.rounded-full.pointer-events-none.top-0.-left-32{class: "bg-[#f5e6e8] blur-[120px] opacity-60 w-[600px] h-[600px]"}
  .absolute.rounded-full.pointer-events-none.-right-32{class: "top-[20%] bg-[#f8f4f2] blur-[100px] opacity-80 w-[500px] h-[500px]"}

  .max-w-7xl.mx-auto.relative.z-10

    .flex.flex-col.justify-between.gap-6.mb-16{class: "md:flex-row md:items-end"}
      .space-y-3
        %p.font-semibold.uppercase.tracking-widest{class: "text-[10px] text-[#8a7b7e]"}
          = t(".overview")
        %h1.text-4xl.font-light.tracking-tight.leading-tight{class: "md:text-5xl text-[#333333]"}
          = t(".welcome_back")
          %br
          %span.italic.font-normal{class: "text-[#675458]"}
            = user.full_name

      = link_to new_teach_course_path, class: "inline-flex items-center justify-center px-8 py-4 rounded-xl text-sm font-medium transition-all text-white shadow-sm hover:shadow-md bg-[#675458] hover:bg-[#5a2e35]" do
        = lucide_icon("plus", class: "w-4 h-4 mr-2")
        = t(".links.create_course")

    .grid.grid-cols-1.gap-6.mb-20{class: "md:grid-cols-3"}
      .p-8.bg-white.flex.flex-col.gap-3{class: "rounded-[2rem] shadow-[0_8px_30px_rgba(0,0,0,0.03)]"}
        %span.font-semibold.uppercase.tracking-widest{class: "text-[10px] text-[#cbb3b6]"}
          = t(".stats.total_courses")
        %span.text-4xl.font-light{class: "text-[#333333]"}
          = created_courses_count

      .p-8.bg-white.flex.flex-col.gap-3{class: "rounded-[2rem] shadow-[0_8px_30px_rgba(0,0,0,0.03)]"}
        %span.font-semibold.uppercase.tracking-widest{class: "text-[10px] text-[#cbb3b6]"}
          = t(".stats.active_students")
        %span.text-4xl.font-light{class: "text-[#333333]"}
          = active_students_count

      .p-8.bg-white.flex.flex-col.gap-3{class: "rounded-[2rem] shadow-[0_8px_30px_rgba(0,0,0,0.03)]"}
        %span.font-semibold.uppercase.tracking-widest{class: "text-[10px] text-[#cbb3b6]"}
          = t(".stats.revenue_ytd")
        %span.text-4xl.font-light{class: "text-[#675458]"}
          = total_revenue

    .flex.items-center.justify-between.mb-10
      %h2.text-2xl.font-light.tracking-tight{class: "text-[#333333]"}
        = t(".courses")

    - if courses.empty?
      .col-span-1{class: "md:col-span-2 lg:col-span-3"}
        = link_to new_teach_course_path, class: "group block w-full p-12 text-center transition-all bg-white border border-transparent rounded-[2.5rem] shadow-[0_8px_30px_rgba(0,0,0,0.02)] hover:shadow-[0_20px_50px_rgba(103,84,88,0.06)] hover:border-[#f5e6e8]" do
          .w-16.h-16.mx-auto.mb-6.rounded-full.flex.items-center.justify-center.transition-colors{class: "bg-[#faf7f6] text-[#bfa2a6] group-hover:text-[#675458] group-hover:bg-[#e9d5d8]"}
            = lucide_icon("plus", class: "w-6 h-6 stroke-[1.5]")

          %h3.text-xl.font-medium.mb-3{class: "text-[#333333]"}
            = t(".empty_state.headline")

          %p.text-sm.max-w-md.mx-auto.mb-6.leading-relaxed{class: "text-[#8a7b7e]"}
            = t(".empty_state.subtext")

          %span.text-sm.font-medium.transition-colors{class: "text-[#675458] group-hover:text-[#5a2e35]"}
            = t(".links.create_course_now")

    - else
      .grid.grid-cols-1.gap-8{class: "md:grid-cols-2 lg:grid-cols-3"}
        - courses.each do |course|
          = render Instructor::CourseCardComponent.new(course)
